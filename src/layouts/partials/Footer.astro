---
interface Props {
  leftItems?: string[];
  rightItems?: string[];
  fixed?: boolean;
  hideOnMobile?: boolean;
}

const {
  leftItems = ['main', 'TypeScript', 'UTF-8'],
  rightItems = ['Ln 1, Col 1', 'Spaces: 2', 'Prettier'],
  fixed = false,
  hideOnMobile = false
} = Astro.props;
---

<footer
  class:list={[
    'border-t border-site-border bg-site-surface',
    fixed ? 'fixed inset-x-0 bottom-0 z-40' : '',
    hideOnMobile ? 'max-sm:hidden' : ''
  ]}
>
  <div class="mx-auto flex w-full max-w-5xl flex-col items-start gap-1.5 px-4 py-2 text-[11px] text-site-dim sm:flex-row sm:items-center sm:justify-between sm:gap-3 sm:px-6 sm:py-1 sm:text-xs lg:px-8">
    <div class="flex flex-wrap items-center gap-x-3 gap-y-1 sm:gap-3.5">
      {
        leftItems.map((item, idx) => (
          <span class:list={idx === 0 ? 'text-site-blue' : ''}>{item}</span>
        ))
      }
    </div>
    <div class="flex flex-wrap items-center gap-x-3 gap-y-1 sm:gap-3.5">
      {
        rightItems.map((item, idx) => (
          <span class:list={idx === rightItems.length - 1 ? 'text-site-green' : ''}>{item}</span>
        ))
      }
    </div>
  </div>
</footer>
