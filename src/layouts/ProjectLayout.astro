---
import BaseLayout from "./BaseLayout.astro";
import CategoryBadge from "../components/projects/CategoryBadge.astro";
import StackPills from "../components/projects/StackPills.astro";
import BackLink from "../components/BackLink.astro";
import { formatDate } from "../lib/utils";
import type { CollectionEntry } from "astro:content";

interface Props {
  project: CollectionEntry<"projects">;
  relatedBlog?: CollectionEntry<"blog"> | null;
}

const { project, relatedBlog } = Astro.props;
const { title, description, date, category, stack, liveUrl, githubUrl } =
  project.data;
---

<BaseLayout title={title} description={description}>
  <BackLink href="/projects" label="Back to projects" />
  <article class="mt-5 sm:mt-6">
    <header class="mb-8">
      <div class="mb-3 flex flex-wrap items-center gap-3">
        <CategoryBadge category={category} />
        <time class="text-xs text-site-dim sm:text-sm">{formatDate(date)}</time>
      </div>
      <h1 class="mb-3 text-2xl font-bold text-site-text sm:text-3xl">
        {title}
      </h1>
      <p class="mb-4 text-base text-site-subtext sm:text-lg">{description}</p>
      {stack && stack.length > 0 && <StackPills stack={stack} />}
      <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-1">
        {
          liveUrl && (
            <a
              href={liveUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-site-blue hover:underline"
            >
              Live ↗
            </a>
          )
        }
        {
          githubUrl && (
            <a
              href={githubUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-site-blue hover:underline"
            >
              GitHub ↗
            </a>
          )
        }
      </div>
      {
        relatedBlog && (
          <div class="mt-6 p-4 border border-site-border rounded-lg bg-site-surface">
            <p class="text-xs text-site-dim mb-1 uppercase tracking-wide font-medium">
              Related
            </p>
            <a
              href={`/blog/${relatedBlog.slug}`}
              class="text-site-blue hover:underline font-medium"
            >
              Read the full write-up →
            </a>
          </div>
        )
      }
    </header>
    <hr class="mb-6 border-site-border sm:mb-8" />
    <div class="prose max-w-none">
      <slot />
    </div>
    <BackLink href="/projects" label="Back to projects" />
  </article>
</BaseLayout>
