---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>My Portfolio.exe — Piotr Szaran</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=VT323&display=swap" rel="stylesheet" />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --desktop: #008080;
      --silver: #C0C0C0;
      --silver-light: #DFDFDF;
      --silver-dark: #808080;
      --silver-darker: #404040;
      --navy: #000080;
      --white: #FFFFFF;
      --black: #000000;
      --btn-face: #C0C0C0;
    }

    html, body {
      background: var(--desktop);
      background-image:
        radial-gradient(ellipse at 20% 80%, rgba(0,100,100,0.3) 0%, transparent 50%),
        radial-gradient(ellipse at 80% 20%, rgba(0,60,80,0.2) 0%, transparent 50%);
      min-height: 100vh;
      font-family: 'VT323', 'Courier New', monospace;
      font-size: 16px;
      color: var(--black);
      display: flex;
      align-items: flex-start;
      justify-content: center;
      padding: 24px 16px 80px;
    }

    /* ── WIN95 MIXINS ── */
    .raised {
      box-shadow:
        inset 1px 1px 0 var(--white),
        inset -1px -1px 0 var(--silver-darker),
        inset 2px 2px 0 var(--silver-light),
        inset -2px -2px 0 var(--silver-dark);
    }

    .sunken {
      box-shadow:
        inset -1px -1px 0 var(--white),
        inset 1px 1px 0 var(--silver-darker),
        inset -2px -2px 0 var(--silver-light),
        inset 2px 2px 0 var(--silver-dark);
    }

    .btn {
      background: var(--silver);
      padding: 4px 16px;
      font-family: 'VT323', monospace;
      font-size: 16px;
      cursor: pointer;
      color: var(--black);
      border: none;
      min-width: 80px;
    }
    .btn:active {
      box-shadow:
        inset 1px 1px 0 var(--silver-darker),
        inset -1px -1px 0 var(--white),
        inset 2px 2px 0 var(--silver-dark),
        inset -2px -2px 0 var(--silver-light);
    }

    /* ── WINDOW ── */
    .window {
      background: var(--silver);
      width: 100%;
      max-width: 820px;
    }

    /* Title bar */
    .title-bar {
      background: linear-gradient(to right, var(--navy), #1084d0);
      padding: 3px 4px;
      display: flex;
      align-items: center;
      gap: 4px;
      user-select: none;
    }

    .title-bar-icon {
      width: 16px;
      height: 16px;
      background: var(--silver);
      font-size: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'VT323', monospace;
    }

    .title-bar-text {
      flex: 1;
      color: var(--white);
      font-family: 'VT323', monospace;
      font-size: 16px;
      letter-spacing: 0.05em;
    }

    .title-bar-controls { display: flex; gap: 2px; }
    .tb-btn {
      background: var(--silver);
      width: 16px;
      height: 14px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 11px;
      cursor: pointer;
      font-family: Arial, sans-serif;
      line-height: 1;
    }

    /* Menu bar */
    .menu-bar {
      background: var(--silver);
      padding: 2px 4px;
      display: flex;
      gap: 0;
      border-bottom: 1px solid var(--silver-dark);
    }

    .menu-item {
      padding: 2px 8px;
      font-size: 15px;
      cursor: default;
      font-family: 'VT323', monospace;
    }
    .menu-item:hover { background: var(--navy); color: var(--white); }
    .menu-item:first-child { text-decoration: underline; }

    /* Content area */
    .content {
      padding: 16px;
    }

    /* Address bar */
    .address-bar {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 12px;
      font-size: 14px;
    }
    .address-label { font-size: 14px; white-space: nowrap; }
    .address-field {
      flex: 1;
      background: var(--white);
      padding: 2px 6px;
      font-family: 'VT323', monospace;
      font-size: 15px;
    }

    /* HERO SECTION — like a properties dialog */
    .hero-dialog {
      background: var(--silver);
      padding: 12px;
      margin-bottom: 12px;
    }

    .hero-dialog-title {
      background: linear-gradient(to right, var(--navy), #1084d0);
      color: var(--white);
      padding: 2px 8px;
      font-size: 16px;
      margin: -12px -12px 12px;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: 80px 1fr;
      gap: 4px 8px;
      font-size: 15px;
    }

    .hero-icon-box {
      grid-row: 1 / 4;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--white);
      font-size: 48px;
      line-height: 1;
      padding: 8px;
    }

    .field-label { color: var(--black); white-space: nowrap; }
    .field-value {
      background: var(--white);
      padding: 1px 4px;
      font-size: 15px;
    }

    .big-name {
      font-size: 28px;
      background: var(--white);
      padding: 2px 6px;
      font-family: 'VT323', monospace;
    }

    /* TABS */
    .tabs { margin-bottom: -1px; display: flex; gap: 2px; }
    .tab {
      background: var(--silver-dark);
      color: var(--silver-light);
      padding: 3px 14px 4px;
      font-size: 15px;
      cursor: pointer;
      border-top: 1px solid var(--silver-dark);
    }
    .tab.active {
      background: var(--silver);
      color: var(--black);
      border-top: 2px solid var(--silver-light);
      border-left: 1px solid var(--silver-darker);
      border-right: 1px solid var(--silver-darker);
      margin-bottom: -1px;
      padding-bottom: 5px;
    }

    .tab-content {
      border-top: 1px solid var(--silver-dark);
      padding: 12px;
      background: var(--silver);
    }

    /* LIST VIEW — like Windows Explorer */
    .list-view { width: 100%; border-collapse: collapse; font-size: 15px; }
    .list-view thead tr {
      background: var(--silver);
    }
    .list-view th {
      text-align: left;
      padding: 2px 8px;
      border-right: 1px solid var(--silver-dark);
      font-size: 14px;
      font-weight: normal;
      cursor: default;
    }
    .list-view td {
      padding: 1px 8px;
      border-bottom: 1px solid transparent;
      vertical-align: top;
    }
    .list-view tr:nth-child(odd) td { background: var(--white); }
    .list-view tr:nth-child(even) td { background: #f0f0f0; }
    .list-view tr:hover td { background: var(--navy); color: var(--white); }

    .cat-badge {
      display: inline-block;
      padding: 0 4px;
      font-size: 13px;
      color: var(--black);
    }
    .cat-badge.personal { color: #008000; }
    .cat-badge.freelance { color: var(--navy); }
    .cat-badge.work { color: #800000; }

    /* STATUS BAR */
    .status-bar {
      background: var(--silver);
      border-top: 1px solid var(--silver-dark);
      padding: 2px 8px;
      display: flex;
      gap: 2px;
      font-size: 13px;
    }
    .status-section {
      flex: 1;
      padding: 1px 4px;
      font-size: 13px;
    }
    .status-section:not(:last-child) { border-right: 1px solid var(--silver-dark); }

    /* STACK TAGS */
    .stack-wrap { display: flex; flex-wrap: wrap; gap: 4px; padding: 8px 0; }
    .sw-tag {
      background: var(--white);
      border: 1px solid var(--silver-dark);
      padding: 1px 8px;
      font-size: 14px;
    }

    @media (max-width: 600px) {
      .list-view th:nth-child(4),
      .list-view td:nth-child(4) { display: none; }
      .hero-grid { grid-template-columns: 1fr; }
      .hero-icon-box { display: none; }
    }

    .switcher {
      position: fixed;
      bottom: 16px;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      align-items: center;
      gap: 12px;
      background: var(--silver);
      padding: 6px 16px;
      font-size: 15px;
      z-index: 200;
      white-space: nowrap;
      font-family: 'VT323', monospace;
    }
    .switcher a { color: var(--navy); text-decoration: underline; font-weight: bold; }
  </style>
</head>
<body>
  <div class="window raised">
    <!-- Title Bar -->
    <div class="title-bar">
      <div class="title-bar-icon">⊞</div>
      <span class="title-bar-text">My Portfolio.exe — Piotr Szaran</span>
      <div class="title-bar-controls">
        <div class="tb-btn raised">_</div>
        <div class="tb-btn raised">□</div>
        <div class="tb-btn raised">✕</div>
      </div>
    </div>

    <!-- Menu Bar -->
    <div class="menu-bar">
      <span class="menu-item">File</span>
      <span class="menu-item">Edit</span>
      <span class="menu-item">View</span>
      <span class="menu-item">Hire</span>
      <span class="menu-item">Help</span>
    </div>

    <div class="content">
      <!-- Address Bar -->
      <div class="address-bar">
        <span class="address-label">Address</span>
        <div class="address-field sunken">C:\Users\Recruiter\Desktop\piotrszaran.exe</div>
        <button class="btn raised">Go</button>
      </div>

      <!-- Developer Info Panel -->
      <div class="hero-dialog raised" style="margin-bottom: 12px;">
        <div class="hero-dialog-title">Developer Properties</div>
        <div class="hero-grid">
          <div class="hero-icon-box">👨‍💻</div>
          <div class="field-label">Full Name:</div>
          <div class="big-name">Piotr Szaran</div>
          <div class="field-label">Role:</div>
          <div class="field-value">Software Developer · Seeking Full-Time</div>
          <div class="field-label">Education:</div>
          <div class="field-value">— update this field</div>
          <div class="field-label">Status:</div>
          <div class="field-value" style="color: green; font-weight: bold;">● Available</div>
        </div>
        <div style="margin-top: 10px;">
          <div class="field-label" style="margin-bottom: 4px;">Core Technologies:</div>
          <div class="stack-wrap">
            <span class="sw-tag raised">TypeScript</span>
            <span class="sw-tag raised">Node.js</span>
            <span class="sw-tag raised">React</span>
            <span class="sw-tag raised">PostgreSQL</span>
            <span class="sw-tag raised">Astro</span>
            <span class="sw-tag raised">Docker</span>
          </div>
        </div>
      </div>

      <!-- Project tabs -->
      <div>
        <div class="tabs">
          <div class="tab active">Projects (4)</div>
          <div class="tab">Blog</div>
          <div class="tab">Contact</div>
        </div>
        <div class="tab-content sunken">
          <table class="list-view">
            <thead>
              <tr>
                <th class="raised">Name</th>
                <th class="raised">Category</th>
                <th class="raised">Description</th>
                <th class="raised">Date Modified</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>📁 Portfolio-v2</td>
                <td><span class="cat-badge personal">[personal]</span></td>
                <td>Astro rebuild, MDX, Tailwind, zero JS</td>
                <td>03/15/2025</td>
              </tr>
              <tr>
                <td>📁 Ecommerce-Dashboard</td>
                <td><span class="cat-badge freelance">[freelance]</span></td>
                <td>Analytics & inventory for UK retailer</td>
                <td>11/08/2024</td>
              </tr>
              <tr>
                <td>📁 Dev-Tools-Suite</td>
                <td><span class="cat-badge work">[work]</span></td>
                <td>CLI tooling & deployment dashboard</td>
                <td>08/22/2024</td>
              </tr>
              <tr>
                <td>📁 URL-Shortener-OSS</td>
                <td><span class="cat-badge personal">[personal]</span></td>
                <td>Self-hosted shortener, REST API, analytics</td>
                <td>05/11/2024</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Status Bar -->
    <div class="status-bar">
      <span class="status-section">4 object(s)</span>
      <span class="status-section">Ready to hire</span>
      <span class="status-section">📧 piotr@piotrszaran.com</span>
    </div>
  </div>

  <nav class="switcher raised">
    <a href="/4">←</a>
    <span>Design 5 / 10 — Win95</span>
    <a href="/6">→</a>
  </nav>
</body>
</html>
