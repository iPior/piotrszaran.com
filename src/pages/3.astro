---
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Design 3 — Broadsheet — Piotr Szaran</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,400;1,700&family=Merriweather:ital,wght@0,300;0,400;1,300&display=swap" rel="stylesheet" />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --newsprint: #F8F4EC;
      --ink: #1A1209;
      --ink-mid: #4A3F35;
      --ink-light: #8A7E72;
      --red: #8B1C1C;
      --rule: #C8BFAC;
    }

    html, body {
      background: var(--newsprint);
      color: var(--ink);
      font-family: 'Merriweather', serif;
      font-size: 14px;
      line-height: 1.7;
    }

    .page {
      max-width: 980px;
      margin: 0 auto;
      padding: 0 28px 100px;
    }

    /* MASTHEAD */
    .masthead {
      text-align: center;
      padding: 24px 0 16px;
      border-bottom: 3px double var(--ink);
      margin-bottom: 0;
    }

    .masthead-eyebrow {
      font-size: 10px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--ink-light);
      margin-bottom: 8px;
    }

    .masthead-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(36px, 7vw, 80px);
      font-weight: 900;
      line-height: 1;
      letter-spacing: -1px;
      color: var(--ink);
      margin-bottom: 10px;
    }

    .masthead-tagline {
      font-size: 11px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--ink-mid);
      border-top: 1px solid var(--rule);
      border-bottom: 1px solid var(--rule);
      padding: 5px 0;
      margin-top: 10px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    /* TOP BAR */
    .top-bar {
      display: flex;
      justify-content: space-between;
      font-size: 10px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--ink-light);
      padding: 6px 0;
      border-bottom: 1px solid var(--rule);
    }

    /* MAIN GRID */
    .main-grid {
      display: grid;
      grid-template-columns: 2fr 1px 1fr;
      gap: 0;
      margin-top: 20px;
    }

    .col-rule { background: var(--rule); margin: 0 20px; }

    /* LEAD STORY */
    .lead-story { padding-right: 24px; }

    .story-kicker {
      font-size: 10px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--red);
      font-weight: 700;
      margin-bottom: 8px;
      font-family: 'Merriweather', serif;
    }

    .story-headline {
      font-family: 'Playfair Display', serif;
      font-size: clamp(24px, 4vw, 42px);
      font-weight: 900;
      line-height: 1.1;
      color: var(--ink);
      margin-bottom: 12px;
    }

    .story-byline {
      font-size: 11px;
      letter-spacing: 0.08em;
      color: var(--ink-light);
      border-top: 1px solid var(--rule);
      border-bottom: 1px solid var(--rule);
      padding: 5px 0;
      margin-bottom: 12px;
      text-transform: uppercase;
    }

    .story-body {
      font-size: 13.5px;
      line-height: 1.75;
      color: var(--ink-mid);
      font-weight: 300;
    }

    .story-body p { margin-bottom: 10px; }

    .pull-quote {
      font-family: 'Playfair Display', serif;
      font-size: 18px;
      font-style: italic;
      color: var(--ink);
      border-top: 2px solid var(--ink);
      border-bottom: 2px solid var(--ink);
      padding: 12px 0;
      margin: 16px 0;
      line-height: 1.4;
    }

    .stack-inline { display: flex; flex-wrap: wrap; gap: 4px; margin-top: 8px; }
    .s-tag {
      font-size: 10px;
      border: 1px solid var(--rule);
      padding: 2px 6px;
      color: var(--ink-mid);
      letter-spacing: 0.05em;
      font-family: 'Merriweather', serif;
    }

    /* SIDEBAR */
    .sidebar { padding-left: 4px; }

    .sidebar-section { margin-bottom: 20px; }

    .sidebar-head {
      font-family: 'Playfair Display', serif;
      font-size: 14px;
      font-weight: 700;
      border-bottom: 2px solid var(--ink);
      padding-bottom: 4px;
      margin-bottom: 10px;
    }

    .brief {
      border-bottom: 1px solid var(--rule);
      padding-bottom: 10px;
      margin-bottom: 10px;
    }

    .brief-cat {
      font-size: 9px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--red);
      font-weight: 700;
      margin-bottom: 2px;
    }

    .brief-title {
      font-family: 'Playfair Display', serif;
      font-size: 14px;
      font-weight: 700;
      line-height: 1.2;
      color: var(--ink);
      margin-bottom: 3px;
    }

    .brief-desc {
      font-size: 11.5px;
      color: var(--ink-mid);
      font-weight: 300;
      line-height: 1.5;
    }

    .brief-stack {
      font-size: 10px;
      color: var(--ink-light);
      margin-top: 4px;
      font-style: italic;
    }

    /* AD BOX */
    .ad-box {
      border: 2px solid var(--ink);
      padding: 14px;
      text-align: center;
      margin-top: 16px;
    }
    .ad-box-title {
      font-family: 'Playfair Display', serif;
      font-size: 16px;
      font-weight: 900;
      margin-bottom: 4px;
    }
    .ad-box-sub { font-size: 11px; color: var(--ink-mid); font-style: italic; }

    /* FULL WIDTH PROJECTS SECTION */
    .full-section {
      border-top: 3px double var(--ink);
      margin-top: 24px;
      padding-top: 16px;
    }

    .full-section-head {
      font-family: 'Playfair Display', serif;
      font-size: 22px;
      font-weight: 900;
      text-align: center;
      margin-bottom: 14px;
      border-bottom: 1px solid var(--rule);
      padding-bottom: 12px;
    }

    .projects-cols {
      display: grid;
      grid-template-columns: 1fr 1px 1fr;
      gap: 0;
    }

    .proj-col { padding: 0 20px; }
    .proj-col:first-child { padding-left: 0; }
    .proj-col:last-child { padding-right: 0; }

    .proj-rule { background: var(--rule); }

    .proj-num {
      font-family: 'Playfair Display', serif;
      font-size: 11px;
      font-style: italic;
      color: var(--ink-light);
      margin-bottom: 4px;
    }
    .proj-name {
      font-family: 'Playfair Display', serif;
      font-size: 17px;
      font-weight: 700;
      line-height: 1.2;
      margin-bottom: 4px;
    }
    .proj-desc {
      font-size: 12px;
      color: var(--ink-mid);
      font-weight: 300;
      line-height: 1.6;
    }
    .proj-stack-r { font-size: 10px; color: var(--ink-light); font-style: italic; margin-top: 6px; }

    @media (max-width: 680px) {
      .main-grid { grid-template-columns: 1fr; }
      .col-rule { display: none; }
      .lead-story { padding-right: 0; }
      .sidebar { padding-left: 0; padding-top: 20px; }
      .projects-cols { grid-template-columns: 1fr; }
      .proj-rule { display: none; }
      .proj-col { padding: 0; margin-bottom: 16px; }
    }

    .switcher {
      position: fixed;
      bottom: 20px;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      align-items: center;
      gap: 16px;
      background: var(--ink);
      color: var(--newsprint);
      padding: 8px 20px;
      font-size: 11px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      z-index: 200;
      white-space: nowrap;
      font-family: 'Merriweather', serif;
      font-style: italic;
    }
    .switcher a { color: var(--red); text-decoration: none; font-style: normal; }
    .switcher a:hover { text-decoration: underline; }
  </style>
</head>
<body>
  <div class="page">
    <div class="top-bar">
      <span>Est. 2025</span>
      <span>piotrszaran.com</span>
      <span>Software & Technology</span>
    </div>

    <header class="masthead">
      <div class="masthead-eyebrow">The Developer Portfolio</div>
      <div class="masthead-title">PIOTR SZARAN</div>
      <div class="masthead-tagline">
        <span>Full-Stack Development</span>
        <span>★ Available for Hire ★</span>
        <span>April 2025</span>
      </div>
    </header>

    <div class="main-grid">
      <div class="lead-story">
        <div class="story-kicker">Career Update</div>
        <h1 class="story-headline">Software Developer Seeks Full-Time Role; Portfolio Rebuilt from Scratch</h1>
        <div class="story-byline">By Piotr Szaran · Staff Reporter · April 2025</div>
        <div class="story-body">
          <p>A seasoned software developer with a focus on TypeScript, Node.js, and modern web technologies is actively seeking full-time opportunities across Europe and remote positions globally.</p>

          <div class="pull-quote">"The goal is always working software that solves real problems — not impressive-looking code that falls over in production."</div>

          <p>With experience spanning freelance client work, in-house engineering roles, and personal open-source projects, the candidate brings a practical, delivery-focused approach to software development.</p>

          <p><strong>Education:</strong> — update this field.</p>
          <p><strong>Currently studying:</strong> — update this field.</p>

          <p>Core competencies include:</p>
          <div class="stack-inline">
            <span class="s-tag">TypeScript</span>
            <span class="s-tag">Node.js</span>
            <span class="s-tag">React</span>
            <span class="s-tag">PostgreSQL</span>
            <span class="s-tag">Astro</span>
            <span class="s-tag">Docker</span>
          </div>
        </div>
      </div>

      <div class="col-rule"></div>

      <div class="sidebar">
        <div class="sidebar-section">
          <div class="sidebar-head">Project Briefs</div>

          <div class="brief">
            <div class="brief-cat">Personal</div>
            <div class="brief-title">Portfolio Site v2</div>
            <div class="brief-desc">Complete rebuild using Astro framework. Zero JavaScript shipped to browser by default.</div>
            <div class="brief-stack">Astro · MDX · Tailwind · Mar 2025</div>
          </div>

          <div class="brief">
            <div class="brief-cat">Freelance</div>
            <div class="brief-title">E-Commerce Dashboard</div>
            <div class="brief-desc">Analytics platform for UK fashion retailer. Real-time inventory and revenue data.</div>
            <div class="brief-stack">Next.js · TypeScript · PostgreSQL · Nov 2024</div>
          </div>
        </div>

        <div class="ad-box">
          <div class="ad-box-title">Available for Hire</div>
          <div class="ad-box-sub">Full-time · Remote or On-site<br />Open to immediate start</div>
        </div>
      </div>
    </div>

    <div class="full-section">
      <div class="full-section-head">Further Project Coverage</div>
      <div class="projects-cols">
        <div class="proj-col">
          <div class="proj-num">Work · Aug 2024</div>
          <div class="proj-name">Developer Tools Suite</div>
          <div class="proj-desc">Internal CLI tooling and web dashboard built to streamline deployment pipelines and reduce toil for a small engineering team.</div>
          <div class="proj-stack-r">Node.js · TypeScript · React · Docker</div>
        </div>
        <div class="proj-rule"></div>
        <div class="proj-col">
          <div class="proj-num">Personal · May 2024</div>
          <div class="proj-name">Open Source URL Shortener</div>
          <div class="proj-desc">Self-hosted shortener with analytics, custom domain support, and a documented REST API. Available on GitHub under MIT license.</div>
          <div class="proj-stack-r">Bun · Hono · SQLite · Fly.io</div>
        </div>
      </div>
    </div>
  </div>

  <nav class="switcher">
    <a href="/2">←</a>
    <span>Design 3 / 10 — Broadsheet</span>
    <a href="/4">→</a>
  </nav>
</body>
</html>
