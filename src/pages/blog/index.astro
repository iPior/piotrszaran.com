---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogPageIntro from "../../components/blog/BlogPageIntro.astro";
import BlogPostsList from "../../components/blog/BlogPostsList.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft && !data.hidden)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<BaseLayout
  title="Blog — Piotr Szaran"
  description="Technical writing on software development."
>
  <BlogPageIntro />
  <BlogPostsList posts={posts} />
</BaseLayout>
