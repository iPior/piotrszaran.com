---
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Design 1 — Terminal — Piotr Szaran</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;700&display=swap" rel="stylesheet" />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --green: #39ff14;
      --green-dim: #1a6b08;
      --green-mid: #2ab80a;
      --bg: #0a0a0a;
      --bg2: #111;
    }

    html, body {
      background: var(--bg);
      color: var(--green);
      font-family: 'JetBrains Mono', monospace;
      font-size: 14px;
      line-height: 1.6;
      min-height: 100vh;
    }

    .terminal-wrap {
      max-width: 860px;
      margin: 0 auto;
      padding: 40px 24px 100px;
    }

    /* Title bar */
    .titlebar {
      background: var(--green-dim);
      color: var(--bg);
      padding: 4px 12px;
      font-size: 12px;
      font-weight: 700;
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-radius: 6px 6px 0 0;
    }

    .dots { display: flex; gap: 6px; }
    .dot {
      width: 12px; height: 12px; border-radius: 50%;
      background: var(--green-dim);
      border: 1px solid var(--green-mid);
    }

    .window {
      border: 1px solid var(--green-dim);
      border-top: none;
      border-radius: 0 0 6px 6px;
      padding: 32px;
      background: var(--bg2);
    }

    /* Prompt line */
    .prompt { color: var(--green-dim); }
    .prompt-user { color: var(--green); font-weight: 700; }
    .prompt-path { color: var(--green-mid); }
    .prompt-sym { color: var(--green); }
    .cmd { color: #fff; }

    .line { margin-bottom: 4px; }
    .block { margin-bottom: 28px; }

    .output { color: var(--green-mid); padding-left: 0; }
    .output-dim { color: var(--green-dim); }
    .output-white { color: #ccc; }

    /* Big name */
    .whoami-output {
      font-size: 42px;
      font-weight: 700;
      color: var(--green);
      letter-spacing: -1px;
      line-height: 1;
      margin: 8px 0 4px;
    }

    .role-output {
      color: var(--green-mid);
      font-size: 16px;
      margin-bottom: 4px;
    }

    /* Key-value pairs */
    .kv { display: flex; gap: 16px; margin-bottom: 2px; }
    .kv-key { color: var(--green-dim); min-width: 120px; }
    .kv-val { color: #d0ffd0; }

    /* Stack tags */
    .stack-list { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 8px; }
    .stack-tag {
      background: transparent;
      border: 1px solid var(--green-dim);
      color: var(--green-mid);
      padding: 2px 10px;
      font-size: 12px;
      font-family: 'JetBrains Mono', monospace;
    }

    /* Projects */
    .projects-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      margin-top: 12px;
    }

    @media (max-width: 600px) {
      .projects-grid { grid-template-columns: 1fr; }
      .whoami-output { font-size: 28px; }
    }

    .project-card {
      border: 1px solid var(--green-dim);
      padding: 14px 16px;
      background: #0d0d0d;
      position: relative;
      cursor: default;
    }

    .project-card:hover { border-color: var(--green); }

    .project-name {
      color: var(--green);
      font-weight: 700;
      font-size: 13px;
      margin-bottom: 4px;
    }

    .project-cat {
      font-size: 11px;
      color: var(--green-dim);
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 6px;
    }

    .project-desc {
      color: #9ad09a;
      font-size: 12px;
      line-height: 1.5;
      margin-bottom: 8px;
    }

    .project-stack { display: flex; flex-wrap: wrap; gap: 4px; }
    .p-tag {
      font-size: 10px;
      color: var(--green-dim);
      border: 1px solid #1a3d0a;
      padding: 1px 6px;
    }

    /* Cursor */
    @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }
    .cursor {
      display: inline-block;
      width: 10px;
      height: 16px;
      background: var(--green);
      vertical-align: middle;
      animation: blink 1.1s step-end infinite;
      margin-left: 2px;
    }

    /* Scan line effect */
    body::after {
      content: '';
      position: fixed;
      inset: 0;
      background: repeating-linear-gradient(
        0deg,
        transparent,
        transparent 2px,
        rgba(0,0,0,0.08) 2px,
        rgba(0,0,0,0.08) 4px
      );
      pointer-events: none;
      z-index: 100;
    }

    .divider { border: none; border-top: 1px solid var(--green-dim); margin: 24px 0; }

    /* Switcher */
    .switcher {
      position: fixed;
      bottom: 20px;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      align-items: center;
      gap: 16px;
      background: rgba(10,10,10,0.95);
      border: 1px solid var(--green-dim);
      padding: 7px 18px;
      font-size: 12px;
      color: var(--green-mid);
      z-index: 200;
      white-space: nowrap;
    }
    .switcher a {
      color: var(--green);
      text-decoration: none;
      font-weight: 700;
    }
    .switcher a:hover { text-decoration: underline; }
  </style>
</head>
<body>
  <div class="terminal-wrap">
    <div class="titlebar">
      <div class="dots">
        <div class="dot"></div>
        <div class="dot"></div>
        <div class="dot"></div>
      </div>
      <span>piotr@portfolio — bash — 120×40</span>
      <span></span>
    </div>
    <div class="window">

      <div class="block">
        <div class="line">
          <span class="prompt-user">piotr</span><span class="prompt">@</span><span class="prompt-path">portfolio</span><span class="prompt">:</span><span class="prompt-path">~</span><span class="prompt-sym">$</span>
          <span class="cmd"> whoami --verbose</span>
        </div>
        <div class="whoami-output">Piotr Szaran</div>
        <div class="role-output">Software developer — open to full-time roles</div>
        <br />
        <div class="kv"><span class="kv-key">education</span><span class="kv-val">— update this field</span></div>
        <div class="kv"><span class="kv-key">currently</span><span class="kv-val">— update this field</span></div>
        <div class="kv"><span class="kv-key">location</span><span class="kv-val">— update this field</span></div>
        <div class="kv"><span class="kv-key">available</span><span class="kv-val">yes</span></div>
      </div>

      <hr class="divider" />

      <div class="block">
        <div class="line">
          <span class="prompt-user">piotr</span><span class="prompt">@</span><span class="prompt-path">portfolio</span><span class="prompt">:</span><span class="prompt-path">~</span><span class="prompt-sym">$</span>
          <span class="cmd"> cat skills.txt</span>
        </div>
        <div class="stack-list">
          <span class="stack-tag">TypeScript</span>
          <span class="stack-tag">Node.js</span>
          <span class="stack-tag">React</span>
          <span class="stack-tag">PostgreSQL</span>
          <span class="stack-tag">Astro</span>
          <span class="stack-tag">Docker</span>
        </div>
      </div>

      <hr class="divider" />

      <div class="block">
        <div class="line">
          <span class="prompt-user">piotr</span><span class="prompt">@</span><span class="prompt-path">portfolio</span><span class="prompt">:</span><span class="prompt-path">~</span><span class="prompt-sym">$</span>
          <span class="cmd"> ls -la projects/ --sort=date</span>
        </div>
        <div class="output-dim" style="margin: 8px 0 12px;">total 4 entries, sorted by date desc</div>
        <div class="projects-grid">
          <div class="project-card">
            <div class="project-cat">[personal] · 2025-03</div>
            <div class="project-name">Portfolio Site v2</div>
            <div class="project-desc">Rebuilt personal portfolio with Astro, MDX, and Tailwind. Zero JS by default.</div>
            <div class="project-stack">
              <span class="p-tag">Astro</span>
              <span class="p-tag">MDX</span>
              <span class="p-tag">Tailwind</span>
              <span class="p-tag">Preact</span>
            </div>
          </div>
          <div class="project-card">
            <div class="project-cat">[freelance] · 2024-11</div>
            <div class="project-name">E-Commerce Dashboard</div>
            <div class="project-desc">Analytics and inventory dashboard for a UK fashion retailer. Real-time data.</div>
            <div class="project-stack">
              <span class="p-tag">Next.js</span>
              <span class="p-tag">TypeScript</span>
              <span class="p-tag">Recharts</span>
              <span class="p-tag">PostgreSQL</span>
            </div>
          </div>
          <div class="project-card">
            <div class="project-cat">[work] · 2024-08</div>
            <div class="project-name">Developer Tools Suite</div>
            <div class="project-desc">Internal CLI tooling and web dashboard to streamline deployment pipelines.</div>
            <div class="project-stack">
              <span class="p-tag">Node.js</span>
              <span class="p-tag">TypeScript</span>
              <span class="p-tag">React</span>
              <span class="p-tag">Docker</span>
            </div>
          </div>
          <div class="project-card">
            <div class="project-cat">[personal] · 2024-05</div>
            <div class="project-name">Open Source URL Shortener</div>
            <div class="project-desc">Self-hosted shortener with analytics, custom domains, and a REST API.</div>
            <div class="project-stack">
              <span class="p-tag">Bun</span>
              <span class="p-tag">Hono</span>
              <span class="p-tag">SQLite</span>
              <span class="p-tag">Fly.io</span>
            </div>
          </div>
        </div>
      </div>

      <div class="line">
        <span class="prompt-user">piotr</span><span class="prompt">@</span><span class="prompt-path">portfolio</span><span class="prompt">:</span><span class="prompt-path">~</span><span class="prompt-sym">$</span>
        <span class="cursor"></span>
      </div>

    </div>
  </div>

  <nav class="switcher">
    <a href="/10">←</a>
    <span>Design 1 / 10 — Terminal</span>
    <a href="/2">→</a>
  </nav>
</body>
</html>
