---
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>IDE — Tokyo Night — Piotr Szaran</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Geist+Mono:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <style is:inline>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #1a1b26;
      --surface: #16161e;
      --surface-hover: #1f2335;
      --tab-bg: #13131e;
      --border: #292e42;
      --text: #c0caf5;
      --subtext: #a9b1d6;
      --dim: #565f89;
      --overlay: #414868;
      /* syntax colors — Tokyo Night */
      --blue: #7aa2f7;
      --green: #9ece6a;
      --peach: #ff9e64;
      --mauve: #bb9af7;
      --red: #f7768e;
      --yellow: #e0af68;
      --teal: #73daca;
      --pink: #ff007c;
    }

    html, body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Geist Mono', 'Cascadia Code', 'Fira Code', monospace;
      font-size: 13px;
      line-height: 1.65;
      -webkit-font-smoothing: antialiased;
    }

    /* TAB BAR */
    .tab-bar {
      background: var(--tab-bg);
      display: flex;
      align-items: stretch;
      border-bottom: 1px solid var(--border);
      font-size: 12px;
      overflow-x: auto;
    }
    .tab {
      padding: 9px 18px;
      color: var(--dim);
      border-right: 1px solid var(--border);
      display: flex;
      align-items: center;
      gap: 8px;
      white-space: nowrap;
    }
    .tab.active {
      background: var(--bg);
      color: var(--text);
      border-bottom: 2px solid var(--blue);
      margin-bottom: -1px;
    }
    .tab-icon { font-size: 11px; }
    .tab-icon.ts { color: var(--blue); }
    .tab-icon.json { color: var(--yellow); }
    .tab-icon.md { color: var(--subtext); }

    .page {
      max-width: 960px;
      margin: 0 auto;
      padding: 0 32px 100px;
    }

    /* HEADER — statusbar style */
    .site-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 10px 0;
      border-bottom: 1px solid var(--border);
      font-size: 11px;
      color: var(--dim);
    }
    .header-file { color: var(--blue); font-weight: 500; }
    .header-status {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      color: var(--green);
    }
    .header-status::before {
      content: '';
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--green);
    }
    .header-branch { color: var(--mauve); }

    /* HERO */
    .hero {
      padding: 36px 0 0;
    }

    .hero-kicker {
      font-size: 12px;
      color: var(--dim);
      margin-bottom: 10px;
    }
    .hero-kicker .kw { color: var(--mauve); }
    .hero-kicker .str { color: var(--green); }
    .hero-kicker .punc { color: var(--overlay); }

    .hero-name {
      font-size: clamp(42px, 9vw, 84px);
      font-weight: 700;
      line-height: 1;
      letter-spacing: -2px;
      color: var(--text);
    }
    .hero-name .fn { color: var(--blue); }
    .hero-name .type { color: var(--yellow); font-weight: 400; }

    .hero-sub {
      font-size: 13px;
      color: var(--dim);
      margin-top: 10px;
    }
    .hero-sub .comment { color: var(--dim); font-style: italic; }

    /* LINE NUMBERS */
    .line-num {
      display: inline-block;
      width: 28px;
      text-align: right;
      color: var(--dim);
      user-select: none;
      margin-right: 16px;
      font-size: 11px;
      opacity: 0.5;
    }

    /* META GRID */
    .hero-meta {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0;
      border: 1px solid var(--border);
      border-radius: 4px;
      margin-top: 24px;
      background: var(--surface);
      overflow: hidden;
    }

    .hero-meta-item {
      padding: 14px 16px;
      border-bottom: 1px solid var(--border);
    }
    .hero-meta-item:nth-child(odd) { border-right: 1px solid var(--border); }
    .hero-meta-item:nth-last-child(-n+2) { border-bottom: none; }

    .meta-label {
      font-size: 11px;
      color: var(--mauve);
      margin-bottom: 4px;
      font-weight: 400;
    }
    .meta-label::before {
      content: '.';
      color: var(--overlay);
    }

    .meta-value {
      font-size: 13px;
      color: var(--text);
    }
    .meta-value::before {
      content: '"';
      color: var(--green);
    }
    .meta-value::after {
      content: '"';
      color: var(--green);
    }

    .stack-inline { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 6px; }
    .s-pill {
      font-size: 11px;
      color: var(--peach);
      border: 1px solid var(--border);
      padding: 2px 10px;
      border-radius: 3px;
      background: var(--surface-hover);
    }

    /* Prevent quotes on stack container */
    .meta-value:has(.stack-inline)::before,
    .meta-value:has(.stack-inline)::after {
      content: none;
    }
    /* fallback for browsers without :has */
    .meta-value.no-quotes::before,
    .meta-value.no-quotes::after {
      content: none;
    }

    /* PROJECTS */
    .section-header {
      display: flex;
      align-items: baseline;
      gap: 12px;
      margin: 40px 0 0;
      padding-bottom: 10px;
      border-bottom: 1px solid var(--border);
    }

    .section-title {
      font-size: 18px;
      font-weight: 600;
      color: var(--text);
    }
    .section-title .kw { color: var(--mauve); font-weight: 400; }
    .section-title .type { color: var(--yellow); }

    .section-count {
      font-size: 11px;
      color: var(--dim);
    }

    .projects-list { margin-top: 0; }

    .project-row {
      display: grid;
      grid-template-columns: 36px 1fr 170px;
      align-items: start;
      gap: 16px;
      padding: 16px 0;
      border-bottom: 1px solid var(--border);
      transition: background 0.12s;
    }
    .project-row:hover {
      background: var(--surface-hover);
      margin: 0 -12px;
      padding-left: 12px;
      padding-right: 12px;
      border-radius: 3px;
    }

    .project-num {
      font-size: 18px;
      font-weight: 500;
      color: var(--peach);
      line-height: 1.2;
    }

    .project-name {
      font-size: 15px;
      font-weight: 600;
      color: var(--blue);
      margin-bottom: 3px;
      line-height: 1.3;
    }

    .project-desc {
      font-size: 12px;
      color: var(--dim);
      line-height: 1.5;
      font-style: italic;
    }

    .project-right {
      text-align: right;
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 8px;
    }

    .project-cat {
      display: inline-block;
      font-size: 10px;
      letter-spacing: 0.06em;
      padding: 2px 8px;
      border-radius: 3px;
      font-weight: 500;
    }
    .project-cat.personal { color: var(--blue); background: rgba(122, 162, 247, 0.1); }
    .project-cat.freelance { color: var(--peach); background: rgba(255, 158, 100, 0.1); }
    .project-cat.work { color: var(--green); background: rgba(158, 206, 106, 0.1); }

    .project-stack-r { display: flex; flex-wrap: wrap; gap: 4px; justify-content: flex-end; }
    .s-r {
      font-size: 10px;
      color: var(--dim);
      border: 1px solid var(--border);
      padding: 1px 6px;
      border-radius: 2px;
    }

    .project-date {
      font-size: 11px;
      color: var(--dim);
    }

    /* BOTTOM */
    .bottom-rule {
      height: 1px;
      background: var(--border);
      margin-top: 40px;
    }

    /* STATUS BAR at bottom of the editor window */
    .status-bar {
      position: fixed;
      bottom: 48px;
      left: 0;
      right: 0;
      background: var(--surface);
      border-top: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 3px 16px;
      font-size: 11px;
      color: var(--dim);
      z-index: 199;
    }
    .status-bar-left, .status-bar-right { display: flex; align-items: center; gap: 14px; }
    .status-item-blue { color: var(--blue); }
    .status-item-green { color: var(--green); }

    @media (max-width: 640px) {
      .hero-name { font-size: 38px; letter-spacing: -1px; }
      .hero-meta { grid-template-columns: 1fr; }
      .hero-meta-item:nth-child(odd) { border-right: none; }
      .hero-meta-item:nth-last-child(-n+2) { border-bottom: 1px solid var(--border); }
      .hero-meta-item:last-child { border-bottom: none; }
      .project-row { grid-template-columns: 28px 1fr; }
      .project-right { display: none; }
      .status-bar { display: none; }
      .tab { padding: 8px 12px; font-size: 11px; }
    }
  </style>
</head>
<body>
  <div class="tab-bar">
    <div class="tab active">
      <span class="tab-icon ts">{}</span>
      portfolio.ts
    </div>
    <div class="tab">
      <span class="tab-icon json">{}</span>
      package.json
    </div>
    <div class="tab">
      <span class="tab-icon md">#</span>
      README.md
    </div>
  </div>

  <div class="page">
    <header class="site-header">
      <span class="header-file">portfolio.ts</span>
      <span class="header-status">Available for hire</span>
      <span class="header-branch">main</span>
    </header>

    <section class="hero">
      <div class="hero-kicker"><span class="kw">export</span> <span class="kw">const</span> developer <span class="punc">=</span> <span class="punc">{</span></div>
      <h1 class="hero-name"><span class="fn">Piotr</span><br /><span class="type">Szaran</span></h1>
      <div class="hero-sub"><span class="comment">// Software Developer</span></div>

      <div class="hero-meta">
        <div class="hero-meta-item">
          <div class="meta-label">status</div>
          <div class="meta-value">Open to full-time opportunities</div>
        </div>
        <div class="hero-meta-item">
          <div class="meta-label">education</div>
          <div class="meta-value">&mdash; update this field</div>
        </div>
        <div class="hero-meta-item">
          <div class="meta-label">currently</div>
          <div class="meta-value">&mdash; update this field</div>
        </div>
        <div class="hero-meta-item">
          <div class="meta-label">coreStack</div>
          <div class="meta-value no-quotes">
            <div class="stack-inline">
              <span class="s-pill">TypeScript</span>
              <span class="s-pill">Node.js</span>
              <span class="s-pill">React</span>
              <span class="s-pill">PostgreSQL</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section>
      <div class="section-header">
        <h2 class="section-title"><span class="kw">const</span> <span class="type">projects</span></h2>
        <span class="section-count">// 4 items</span>
      </div>
      <div class="projects-list">
        <div class="project-row">
          <div class="project-num">01</div>
          <div class="project-body">
            <div class="project-name">Portfolio Site v2</div>
            <div class="project-desc">Rebuilt personal portfolio with Astro, MDX, and Tailwind. Zero JS by default.</div>
          </div>
          <div class="project-right">
            <span class="project-cat personal">Personal</span>
            <div class="project-stack-r">
              <span class="s-r">Astro</span>
              <span class="s-r">MDX</span>
              <span class="s-r">Tailwind</span>
            </div>
            <span class="project-date">Mar 2025</span>
          </div>
        </div>
        <div class="project-row">
          <div class="project-num">02</div>
          <div class="project-body">
            <div class="project-name">E-Commerce Dashboard</div>
            <div class="project-desc">Analytics and inventory dashboard for a UK fashion retailer. Real-time data.</div>
          </div>
          <div class="project-right">
            <span class="project-cat freelance">Freelance</span>
            <div class="project-stack-r">
              <span class="s-r">Next.js</span>
              <span class="s-r">TypeScript</span>
              <span class="s-r">Recharts</span>
            </div>
            <span class="project-date">Nov 2024</span>
          </div>
        </div>
        <div class="project-row">
          <div class="project-num">03</div>
          <div class="project-body">
            <div class="project-name">Developer Tools Suite</div>
            <div class="project-desc">Internal CLI tooling and web dashboard to streamline deployment pipelines.</div>
          </div>
          <div class="project-right">
            <span class="project-cat work">Work</span>
            <div class="project-stack-r">
              <span class="s-r">Node.js</span>
              <span class="s-r">TypeScript</span>
              <span class="s-r">Docker</span>
            </div>
            <span class="project-date">Aug 2024</span>
          </div>
        </div>
        <div class="project-row">
          <div class="project-num">04</div>
          <div class="project-body">
            <div class="project-name">Open Source URL Shortener</div>
            <div class="project-desc">Self-hosted shortener with analytics, custom domains, and a REST API.</div>
          </div>
          <div class="project-right">
            <span class="project-cat personal">Personal</span>
            <div class="project-stack-r">
              <span class="s-r">Bun</span>
              <span class="s-r">Hono</span>
              <span class="s-r">SQLite</span>
            </div>
            <span class="project-date">May 2024</span>
          </div>
        </div>
      </div>
    </section>

    <div class="bottom-rule"></div>
  </div>

  <div class="status-bar">
    <div class="status-bar-left">
      <span class="status-item-blue">main</span>
      <span>TypeScript</span>
      <span>UTF-8</span>
    </div>
    <div class="status-bar-right">
      <span>Ln 1, Col 1</span>
      <span>Spaces: 2</span>
      <span class="status-item-green">Prettier</span>
    </div>
  </div>
</body>
</html>
