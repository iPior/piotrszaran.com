---
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Terminal 2 — Piotr Szaran</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,300;0,400;0,500;0,700;1,300;1,400&display=swap" rel="stylesheet" />
  <style is:inline>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #0d1117;
      --surface: #161b22;
      --border: #30363d;
      --border-hover: #484f58;
      --muted: #484f58;
      --secondary: #8b949e;
      --primary: #e6edf3;
      --green: #3fb950;
      --blue: #79c0ff;
      --blue-alt: #388bfd;
      --dot-red: #ff5f56;
      --dot-red-border: #e0443e;
      --dot-yellow: #ffbd2e;
      --dot-yellow-border: #dea123;
      --dot-green: #27c93f;
      --dot-green-border: #1aab29;
    }

    html, body {
      background: #0a0e14;
      color: var(--secondary);
      font-family: 'JetBrains Mono', monospace;
      font-size: 13px;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-start;
      padding: 32px 16px 100px;
    }

    /* WINDOW */
    .window {
      width: 100%;
      max-width: 960px;
      border: 1px solid var(--border);
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 24px 64px -16px rgba(0,0,0,0.7);
    }

    /* TITLE BAR */
    .title-bar {
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      padding: 11px 16px;
      display: flex;
      align-items: center;
    }
    .dots {
      display: flex;
      gap: 8px;
      flex-shrink: 0;
    }
    .dot {
      width: 12px;
      height: 12px;
      border-radius: 50%;
    }
    .dot--red { background: var(--dot-red); border: 1px solid var(--dot-red-border); }
    .dot--yellow { background: var(--dot-yellow); border: 1px solid var(--dot-yellow-border); }
    .dot--green { background: var(--dot-green); border: 1px solid var(--dot-green-border); }
    .title-text {
      flex: 1;
      text-align: center;
      font-size: 12px;
      color: var(--muted);
      letter-spacing: 0.04em;
    }
    .dots-spacer { width: 52px; flex-shrink: 0; }

    /* TERMINAL BODY */
    .terminal {
      background: var(--bg);
      padding: 24px 24px 20px;
    }

    @media (min-width: 640px) {
      .terminal { padding: 32px 32px 28px; }
    }

    /* PROMPT */
    .prompt { margin-bottom: 8px; font-size: 13px; }
    .prompt .gt { color: var(--green); font-weight: 700; }
    .prompt .cmd { color: var(--blue); }
    .prompt .arg { color: var(--primary); }

    /* HERO */
    .hero-name {
      font-size: clamp(36px, 8vw, 64px);
      font-weight: 700;
      line-height: 1.05;
      letter-spacing: -1.5px;
      color: var(--primary);
      margin-bottom: 8px;
    }

    .hero-desc {
      color: var(--secondary);
      font-size: 13px;
      line-height: 1.6;
      margin-bottom: 4px;
    }

    .hero-sub {
      color: var(--muted);
      font-size: 12px;
      font-style: italic;
      font-weight: 300;
    }

    /* DIVIDER */
    .divider {
      border: none;
      border-top: 1px solid var(--border);
      margin: 24px 0;
    }

    /* META — key:value pairs */
    .meta-list {
      display: flex;
      flex-direction: column;
      gap: 6px;
      margin-top: 12px;
      font-size: 13px;
    }
    .meta-row {
      display: flex;
      gap: 8px;
    }
    .meta-key {
      color: var(--blue);
      min-width: 100px;
      flex-shrink: 0;
    }
    .meta-val { color: var(--secondary); }

    /* TECH GRID */
    .tech-section { margin-top: 0; }
    .tech-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 12px;
    }
    .tech-pill {
      font-size: 12px;
      color: var(--green);
      border: 1px solid rgba(63, 185, 80, 0.33);
      background: rgba(63, 185, 80, 0.1);
      padding: 3px 12px;
      border-radius: 14px;
    }

    /* PROJECTS */
    .projects-header {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      margin-bottom: 4px;
    }
    .file-count {
      font-size: 11px;
      color: var(--muted);
    }

    .project-row {
      display: grid;
      grid-template-columns: 28px auto 1fr;
      gap: 10px;
      align-items: baseline;
      padding: 12px 0;
      border-bottom: 1px solid var(--border);
    }
    .project-row:last-child { border-bottom: none; }
    .project-row:hover {
      background: var(--surface);
      margin: 0 -12px;
      padding-left: 12px;
      padding-right: 12px;
      border-radius: 6px;
    }

    .project-num {
      font-size: 14px;
      font-weight: 700;
      color: var(--muted);
      font-variant-numeric: tabular-nums;
    }

    .project-cat {
      font-size: 11px;
      font-weight: 500;
      padding: 1px 8px;
      border-radius: 10px;
      border: 1px solid var(--border);
      background: var(--surface);
      color: var(--blue-alt);
      text-transform: capitalize;
      white-space: nowrap;
    }

    .project-info { min-width: 0; }
    .project-name {
      font-size: 14px;
      font-weight: 500;
      color: var(--primary);
      margin-bottom: 2px;
    }
    .project-desc {
      font-size: 12px;
      color: var(--secondary);
      line-height: 1.5;
      font-weight: 300;
    }
    .project-stack {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-top: 6px;
    }
    .project-stack-tag {
      font-size: 10px;
      color: var(--green);
      border: 1px solid rgba(63, 185, 80, 0.33);
      background: rgba(63, 185, 80, 0.1);
      padding: 1px 8px;
      border-radius: 10px;
    }
    .project-links {
      display: flex;
      gap: 12px;
      margin-top: 6px;
      font-size: 11px;
    }
    .project-links a {
      text-decoration: underline;
      text-underline-offset: 2px;
    }
    .project-links a.live { color: var(--green); }
    .project-links a.gh { color: var(--blue); }
    .project-links a:hover { color: #fff; }

    /* CONTACT */
    .contact-row {
      display: flex;
      flex-wrap: wrap;
      gap: 16px;
      margin-top: 12px;
      font-size: 13px;
    }
    .contact-row a {
      color: var(--green);
      text-decoration: underline;
      text-underline-offset: 2px;
    }
    .contact-row a:hover { color: #fff; }
    .contact-label { color: var(--muted); margin-right: 4px; }

    /* BOTTOM PROMPT */
    .bottom-prompt {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-top: 24px;
      padding-top: 16px;
      border-top: 1px solid var(--border);
      font-size: 12px;
      color: var(--muted);
    }
    .bottom-prompt .gt { color: var(--green); font-weight: 700; }
    .cursor {
      display: inline-block;
      width: 7px;
      height: 15px;
      background: var(--green);
      opacity: 0.7;
      animation: blink 1s step-end infinite;
      vertical-align: middle;
    }
    @keyframes blink { 50% { opacity: 0; } }

    /* RESPONSIVE */
    @media (max-width: 640px) {
      body { padding: 0 0 100px; }
      .window {
        border-radius: 0;
        border-left: none;
        border-right: none;
        max-width: 100%;
      }
      .hero-name { font-size: 32px; }
      .project-row { grid-template-columns: 24px 1fr; }
      .project-cat { display: none; }
      .meta-row { flex-direction: column; gap: 2px; }
      .meta-key { min-width: 0; }
    }
  </style>
</head>
<body>
  <div class="window">
    <div class="title-bar">
      <div class="dots">
        <span class="dot dot--red"></span>
        <span class="dot dot--yellow"></span>
        <span class="dot dot--green"></span>
      </div>
      <span class="title-text">piotr@portfolio &mdash; zsh &mdash; 80&times;24</span>
      <span class="dots-spacer"></span>
    </div>

    <div class="terminal">
      <!-- WHOAMI -->
      <div class="prompt"><span class="gt">&gt;</span> <span class="cmd">whoami</span></div>
      <h1 class="hero-name">Piotr Szaran</h1>
      <p class="hero-desc">Software developer &middot; Open to full-time opportunities</p>
      <p class="hero-sub">CS student &middot; Backend reliability &middot; System design &middot; Testing</p>

      <div class="meta-list">
        <div class="meta-row">
          <span class="meta-key">education</span>
          <span class="meta-val">&mdash; update this field</span>
        </div>
        <div class="meta-row">
          <span class="meta-key">currently</span>
          <span class="meta-val">&mdash; update this field</span>
        </div>
        <div class="meta-row">
          <span class="meta-key">status</span>
          <span class="meta-val">Open to full-time opportunities</span>
        </div>
      </div>

      <hr class="divider" />

      <!-- TECH -->
      <div class="tech-section">
        <div class="prompt"><span class="gt">&gt;</span> <span class="cmd">tech</span> <span class="arg">--list</span></div>
        <div class="tech-grid">
          <span class="tech-pill">TypeScript</span>
          <span class="tech-pill">Next.js</span>
          <span class="tech-pill">React</span>
          <span class="tech-pill">Node.js</span>
          <span class="tech-pill">Tailwind CSS</span>
          <span class="tech-pill">PostgreSQL</span>
        </div>
      </div>

      <hr class="divider" />

      <!-- PROJECTS -->
      <div class="projects-header">
        <div class="prompt"><span class="gt">&gt;</span> <span class="cmd">ls</span> <span class="arg">-la ./projects/</span></div>
        <span class="file-count">total 4 projects</span>
      </div>

      <div class="project-row">
        <span class="project-num">01</span>
        <span class="project-cat">personal</span>
        <div class="project-info">
          <div class="project-name">Portfolio Site v2</div>
          <div class="project-desc">A rebuilt personal portfolio using Astro, MDX, and Tailwind. Zero JS by default.</div>
          <div class="project-stack">
            <span class="project-stack-tag">Astro</span>
            <span class="project-stack-tag">MDX</span>
            <span class="project-stack-tag">Tailwind</span>
            <span class="project-stack-tag">Preact</span>
          </div>
          <div class="project-links">
            <a href="#" class="live">Live &nearr;</a>
            <a href="#" class="gh">GitHub &nearr;</a>
          </div>
        </div>
      </div>

      <div class="project-row">
        <span class="project-num">02</span>
        <span class="project-cat">freelance</span>
        <div class="project-info">
          <div class="project-name">Client Operations Dashboard</div>
          <div class="project-desc">A dashboard that unified reporting, travel logs, and session tracking for a consulting firm.</div>
          <div class="project-stack">
            <span class="project-stack-tag">Next.js</span>
            <span class="project-stack-tag">TypeScript</span>
            <span class="project-stack-tag">Recharts</span>
          </div>
          <div class="project-links">
            <a href="#" class="live">Live &nearr;</a>
          </div>
        </div>
      </div>

      <div class="project-row">
        <span class="project-num">03</span>
        <span class="project-cat">work</span>
        <div class="project-info">
          <div class="project-name">Developer Tools Suite</div>
          <div class="project-desc">Internal CLI tooling and web dashboard to streamline deployment pipelines.</div>
          <div class="project-stack">
            <span class="project-stack-tag">Node.js</span>
            <span class="project-stack-tag">TypeScript</span>
            <span class="project-stack-tag">Docker</span>
          </div>
        </div>
      </div>

      <div class="project-row">
        <span class="project-num">04</span>
        <span class="project-cat">personal</span>
        <div class="project-info">
          <div class="project-name">Open Source URL Shortener</div>
          <div class="project-desc">Self-hosted shortener with analytics, custom domains, and a REST API.</div>
          <div class="project-stack">
            <span class="project-stack-tag">Bun</span>
            <span class="project-stack-tag">Hono</span>
            <span class="project-stack-tag">SQLite</span>
          </div>
          <div class="project-links">
            <a href="#" class="gh">GitHub &nearr;</a>
          </div>
        </div>
      </div>

      <hr class="divider" />

      <!-- CONTACT -->
      <div class="prompt"><span class="gt">&gt;</span> <span class="cmd">cat</span> <span class="arg">contact.txt</span></div>
      <div class="contact-row">
        <span><span class="contact-label">email</span> <a href="mailto:piotr@piotrszaran.com">piotr@piotrszaran.com</a></span>
        <span><span class="contact-label">linkedin</span> <a href="https://linkedin.com/in/piotrszaran" target="_blank" rel="noopener noreferrer">linkedin.com/in/piotrszaran</a></span>
        <span><span class="contact-label">github</span> <a href="https://github.com/piotrszaran" target="_blank" rel="noopener noreferrer">.blog</a></span>
      </div>

      <!-- BOTTOM PROMPT -->
      <div class="bottom-prompt">
        <span class="gt">&gt;</span>
        <span>Type a command...</span>
        <span class="cursor"></span>
      </div>
    </div>
  </div>
</body>
</html>
