---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectFilter from "../../components/projects/ProjectFilter";
import ProjectPageIntro from "../../components/projects/ProjectPageIntro.astro";
import { getCollection } from "astro:content";

const projects = (await getCollection("projects", ({ data }) => !data.hidden)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const filterProjects = projects.map((project) => ({
  id: project.slug,
  title: project.data.title,
  description: project.data.description,
  category: project.data.category,
  date: project.data.date.toISOString(),
  stack: project.data.stack ?? [],
  liveUrl: project.data.liveUrl,
  githubUrl: project.data.githubUrl,
}));
---

<BaseLayout
  title="Projects — Piotr Szaran"
  description="Selected software projects, case studies, and build notes."
>
  <ProjectPageIntro />

  <section class="mt-10">
    {
      projects.length === 0 ? (
        <p class="py-6 text-site-dim">No projects yet.</p>
      ) : (
        <ProjectFilter client:load projects={filterProjects} />
      )
    }
  </section>
</BaseLayout>
