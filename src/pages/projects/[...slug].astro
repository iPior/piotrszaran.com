---
import { getCollection, getEntry } from 'astro:content';
import ProjectLayout from '../../features/projects/layouts/ProjectLayout.astro';
import Callout from '../../components/mdx/Callout.astro';
import Image from '../../components/mdx/Image.astro';
import LinkCard from '../../components/mdx/LinkCard.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) => !data.hidden);
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await project.render();

const relatedBlogEntry = project.data.blogSlug
  ? await getEntry('blog', project.data.blogSlug)
  : null;

const relatedBlog = relatedBlogEntry && !relatedBlogEntry.data.draft && !relatedBlogEntry.data.hidden
  ? relatedBlogEntry
  : null;
---

<ProjectLayout project={project} relatedBlog={relatedBlog}>
  <Content components={{ Callout, Image, LinkCard }} />
</ProjectLayout>
