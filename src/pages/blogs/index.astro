---
import AppLayout from "../../layouts/AppLayout.astro";
import BlogPageIntro from "../../features/blog/components/BlogPageIntro.astro";
import BlogPostsList from "../../features/blog/components/BlogPostsList.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft && !data.hidden)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<AppLayout
  title="Blogs — Piotr Szaran"
  description="Technical writing on software development."
>
  <BlogPageIntro />
  <BlogPostsList posts={posts} />
</AppLayout>
