---
import BaseHead from '../components/BaseHead.astro';
import FooterBar from '../components/FooterBar.astro';
import HeaderBar from '../components/HeaderBar.astro';
import BlogSection from '../components/home/BlogSection.astro';
import HeroPanel from '../components/home/HeroPanel.astro';
import NoiseOverlay from '../components/NoiseOverlay.astro';
import ProjectsSection from '../components/home/ProjectsSection.astro';
import { getCollection } from 'astro:content';
import { calculateReadingTime } from '../lib/utils';

const title = 'Piotr Szaran — Portfolio';
const description = 'Software developer portfolio featuring profile details and selected projects.';

const blogPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4)
  .map((post) => ({
    slug: post.slug,
    title: post.data.title,
    description: post.data.description,
    date: post.data.date,
    readingTime: post.data.readingTime ?? calculateReadingTime(post.body ?? ''),
    tags: post.data.tags ?? []
  }));

const projects = (await getCollection('projects'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 15);
---

<!doctype html>
<html lang="en" class="bg-site-bg">
<head>
  <BaseHead title={title} description={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Geist+Mono:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body class="min-h-screen flex flex-col bg-site-bg text-site-text font-mono text-sm leading-relaxed antialiased">
  <NoiseOverlay />
  <HeaderBar />

  <main class="mx-auto flex-1 w-full max-w-5xl px-8 pb-24">
    <HeroPanel
      firstName="Piotr"
      lastName="Szaran"
      role="Full Stack Developer"
      profileImageSrc="/images/profile-avatar.svg"
      profileImageAlt="Piotr Szaran profile picture"
    />

    <ProjectsSection projects={projects} />
    <BlogSection posts={blogPosts} />

  </main>

  <FooterBar />
</body>
</html>
