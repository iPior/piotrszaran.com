---
import AppLayout from '../layouts/AppLayout.astro';
import BlogSection from '../features/home/components/BlogSection.astro';
import HeroPanel from '../features/home/components/HeroPanel.astro';
import ProjectsSection from '../features/home/components/ProjectsSection.astro';
import { getCollection } from 'astro:content';
import profilePhoto from '../assets/images/pior.jpeg';

const title = 'Piotr Szaran — Portfolio';
const description = 'Software developer portfolio featuring profile details and selected projects.';
const BLOG_SECTION_LIMIT = 5;
const PROJECTS_SECTION_LIMIT = 10;

const allBlogPosts = (await getCollection('blog', ({ data }) => !data.draft && !data.hidden))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const blogPosts = allBlogPosts.slice(0, BLOG_SECTION_LIMIT);

const allProjects = (await getCollection('projects', ({ data }) => !data.hidden))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const projects = allProjects.slice(0, PROJECTS_SECTION_LIMIT);
---

<AppLayout
  title={title}
  description={description}
  mainClass="mx-auto flex-1 w-full max-w-5xl px-4 pb-16 sm:px-6 sm:pb-24 lg:px-8"
>
  <HeroPanel
    firstName="Piotr"
    lastName="Szaran"
    role="full stack developer"
    profileImageSrc={profilePhoto}
    profileImageAlt="Piotr Szaran profile picture"
  />

  <ProjectsSection projects={projects} totalProjects={allProjects.length} />
  <BlogSection posts={blogPosts} totalPosts={allBlogPosts.length} />
</AppLayout>
