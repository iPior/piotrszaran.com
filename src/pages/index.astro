---
import BaseHead from '../components/BaseHead.astro';
import FooterBar from '../components/home/FooterBar.astro';
import HeaderBar from '../components/home/HeaderBar.astro';
import HeroPanel from '../components/home/HeroPanel.astro';
import NoiseOverlay from '../components/home/NoiseOverlay.astro';
import ProjectsSection from '../components/home/ProjectsSection.astro';
import TopTabs from '../components/home/TopTabs.astro';
import { coreStack, profileFields, projects, statusBarLeft, statusBarRight, topTabs } from '../data/home/homeTheme';

const title = 'Piotr Szaran — Portfolio';
const description = 'Software developer portfolio featuring profile details and selected projects.';
---

<!doctype html>
<html lang="en" class="bg-site-bg">
<head>
  <BaseHead title={title} description={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Geist+Mono:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body class="bg-site-bg text-site-text font-mono text-sm leading-relaxed antialiased">
  <NoiseOverlay />
  <TopTabs tabs={topTabs} />

  <div class="mx-auto max-w-5xl px-8 pb-24">
    <HeaderBar />

    <HeroPanel
      firstName="Piotr"
      lastName="Szaran"
      role="Software Developer"
      profileFields={profileFields}
      coreStack={coreStack}
    />

    <ProjectsSection projects={projects} />

    <div class="mt-10 h-px bg-site-border"></div>
  </div>

  <FooterBar leftItems={statusBarLeft} rightItems={statusBarRight} />
</body>
</html>
