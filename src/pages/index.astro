---
import BaseHead from '../components/BaseHead.astro';
import FooterBar from '../components/FooterBar.astro';
import HeaderBar from '../components/HeaderBar.astro';
import BlogSection from '../components/home/BlogSection.astro';
import HeroPanel from '../components/home/HeroPanel.astro';
import NoiseOverlay from '../components/NoiseOverlay.astro';
import ProjectsSection from '../components/home/ProjectsSection.astro';
import { coreStack, profileFields, projects, statusBarLeft, statusBarRight } from '../data/home/homeTheme';
import { getCollection } from 'astro:content';
import { calculateReadingTime } from '../lib/utils';

const title = 'Piotr Szaran — Portfolio';
const description = 'Software developer portfolio featuring profile details and selected projects.';

const blogPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4)
  .map((post) => ({
    slug: post.slug,
    title: post.data.title,
    description: post.data.description,
    date: post.data.date,
    readingTime: post.data.readingTime ?? calculateReadingTime(post.body ?? ''),
    tags: post.data.tags ?? []
  }));
---

<!doctype html>
<html lang="en" class="bg-site-bg">
<head>
  <BaseHead title={title} description={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Geist+Mono:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body class="bg-site-bg text-site-text font-mono text-sm leading-relaxed antialiased">
  <NoiseOverlay />
  <HeaderBar />

  <div class="mx-auto max-w-5xl px-8 pb-24">
    <HeroPanel
      firstName="Piotr"
      lastName="Szaran"
      role="Software Developer"
      profileFields={profileFields}
      coreStack={coreStack}
    />

    <ProjectsSection projects={projects} />
    <BlogSection posts={blogPosts} />

  </div>

  <FooterBar leftItems={statusBarLeft} rightItems={statusBarRight} />
</body>
</html>
