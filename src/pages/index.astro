---
import AppLayout from '../layouts/AppLayout.astro';
import BlogSection from '../features/home/components/BlogSection.astro';
import HeroPanel from '../features/home/components/HeroPanel.astro';
import ProjectsSection from '../features/home/components/ProjectsSection.astro';
import { getCollection } from 'astro:content';

const title = 'Piotr Szaran — Portfolio';
const description = 'Software developer portfolio featuring profile details and selected projects.';

const blogPosts = (await getCollection('blog', ({ data }) => !data.draft && !data.hidden))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4);

const projects = (await getCollection('projects', ({ data }) => !data.hidden))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 15);
---

<AppLayout
  title={title}
  description={description}
  mainClass="mx-auto flex-1 w-full max-w-5xl px-4 pb-16 sm:px-6 sm:pb-24 lg:px-8"
>
  <HeroPanel
    firstName="Piotr"
    lastName="Szaran"
    role="full stack developer"
    profileImageSrc="/images/pior.jpeg"
    profileImageAlt="Piotr Szaran profile picture"
  />

  <ProjectsSection projects={projects} />
  <BlogSection posts={blogPosts} />
</AppLayout>
