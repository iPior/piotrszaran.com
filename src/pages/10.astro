---
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Design 10 — Blueprint — Piotr Szaran</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=IBM+Plex+Sans:ital,wght@0,300;0,400;0,500;0,600;1,300&display=swap" rel="stylesheet" />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --blue-deep: #072140;
      --blue-dark: #0A2E5A;
      --blue-mid: #1A4878;
      --blue-line: rgba(90,160,220,0.25);
      --blue-line-major: rgba(90,160,220,0.45);
      --text-primary: #C8E3F5;
      --text-dim: #6A9EC0;
      --text-dimmer: #3A6888;
      --accent: #41B8D4;
      --gold: #F5C842;
      --white: #E8F4FF;
    }

    html, body {
      background: var(--blue-deep);
      color: var(--text-primary);
      font-family: 'IBM Plex Sans', sans-serif;
      font-weight: 300;
      min-height: 100vh;
    }

    /* Blueprint grid background */
    body {
      background-image:
        /* Major grid */
        linear-gradient(var(--blue-line-major) 1px, transparent 1px),
        linear-gradient(90deg, var(--blue-line-major) 1px, transparent 1px),
        /* Minor grid */
        linear-gradient(var(--blue-line) 1px, transparent 1px),
        linear-gradient(90deg, var(--blue-line) 1px, transparent 1px);
      background-size: 80px 80px, 80px 80px, 16px 16px, 16px 16px;
    }

    .page {
      max-width: 960px;
      margin: 0 auto;
      padding: 32px 32px 120px;
    }

    /* TITLE BLOCK — engineering drawing corner */
    .title-block {
      border: 1px solid var(--accent);
      margin-bottom: 32px;
      display: grid;
      grid-template-columns: 1fr 280px;
    }

    .title-main {
      padding: 16px 20px;
      border-right: 1px solid var(--accent);
    }

    .tb-label {
      font-family: 'Share Tech Mono', monospace;
      font-size: 10px;
      color: var(--text-dimmer);
      letter-spacing: 0.2em;
      text-transform: uppercase;
      margin-bottom: 4px;
    }

    .tb-name {
      font-family: 'Share Tech Mono', monospace;
      font-size: clamp(28px, 5vw, 52px);
      color: var(--white);
      letter-spacing: 2px;
      line-height: 1;
      margin-bottom: 4px;
    }

    .tb-sub {
      font-size: 13px;
      color: var(--text-dim);
      font-style: italic;
      font-weight: 300;
    }

    .title-meta {
      display: grid;
      grid-template-rows: 1fr 1fr 1fr;
    }

    .tm-row {
      display: grid;
      grid-template-columns: 80px 1fr;
      border-bottom: 1px solid var(--accent);
    }
    .tm-row:last-child { border-bottom: none; }

    .tm-key {
      background: var(--blue-mid);
      padding: 6px 8px;
      font-family: 'Share Tech Mono', monospace;
      font-size: 9px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--text-dimmer);
      border-right: 1px solid var(--accent);
      display: flex;
      align-items: center;
    }

    .tm-val {
      padding: 6px 10px;
      font-family: 'Share Tech Mono', monospace;
      font-size: 11px;
      color: var(--accent);
      display: flex;
      align-items: center;
    }

    /* FIGURE LABELS */
    .fig-label {
      font-family: 'Share Tech Mono', monospace;
      font-size: 10px;
      letter-spacing: 0.2em;
      color: var(--accent);
      text-transform: uppercase;
      margin-bottom: 8px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .fig-label::after {
      content: '';
      flex: 0 0 24px;
      height: 1px;
      background: var(--accent);
    }

    /* SPEC BLOCKS */
    .spec-block {
      border: 1px solid var(--blue-line-major);
      margin-bottom: 24px;
      position: relative;
    }

    .spec-header {
      background: var(--blue-dark);
      border-bottom: 1px solid var(--blue-line-major);
      padding: 8px 16px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .spec-title {
      font-family: 'Share Tech Mono', monospace;
      font-size: 12px;
      letter-spacing: 0.1em;
      color: var(--accent);
    }

    .spec-tag {
      font-family: 'Share Tech Mono', monospace;
      font-size: 10px;
      color: var(--text-dimmer);
      letter-spacing: 0.08em;
    }

    .spec-body { padding: 16px; }

    /* HERO SPEC */
    .hero-spec .spec-body {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }

    .field-group {}
    .field-key {
      font-family: 'Share Tech Mono', monospace;
      font-size: 9px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--text-dimmer);
      margin-bottom: 4px;
    }
    .field-val {
      font-size: 14px;
      color: var(--text-primary);
      font-weight: 400;
      line-height: 1.4;
    }

    .stack-chips { display: flex; flex-wrap: wrap; gap: 4px; margin-top: 4px; }
    .s-chip {
      font-family: 'Share Tech Mono', monospace;
      font-size: 10px;
      color: var(--accent);
      border: 1px solid var(--accent);
      padding: 2px 8px;
      letter-spacing: 0.05em;
    }
    .s-chip-dim {
      border-color: var(--blue-line-major);
      color: var(--text-dim);
    }

    /* PROJECT GRID */
    .project-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }

    .proj-spec {
      border: 1px solid var(--blue-line-major);
      position: relative;
    }

    /* Corner marks */
    .proj-spec::before, .proj-spec::after {
      content: '';
      position: absolute;
      width: 8px; height: 8px;
      border-color: var(--accent);
      border-style: solid;
    }
    .proj-spec::before {
      top: -1px; left: -1px;
      border-width: 1px 0 0 1px;
    }
    .proj-spec::after {
      bottom: -1px; right: -1px;
      border-width: 0 1px 1px 0;
    }

    .proj-header {
      background: var(--blue-dark);
      border-bottom: 1px solid var(--blue-line-major);
      padding: 8px 12px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .proj-cat-tag {
      font-family: 'Share Tech Mono', monospace;
      font-size: 9px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      padding: 2px 6px;
      border: 1px solid;
    }
    .proj-cat-tag.personal { color: var(--accent); border-color: var(--accent); }
    .proj-cat-tag.freelance { color: var(--gold); border-color: var(--gold); }
    .proj-cat-tag.work { color: var(--text-dim); border-color: var(--text-dimmer); }

    .proj-date {
      font-family: 'Share Tech Mono', monospace;
      font-size: 10px;
      color: var(--text-dimmer);
    }

    .proj-body { padding: 12px; }

    .proj-id {
      font-family: 'Share Tech Mono', monospace;
      font-size: 9px;
      color: var(--text-dimmer);
      letter-spacing: 0.1em;
      margin-bottom: 4px;
    }

    .proj-name {
      font-size: 16px;
      font-weight: 500;
      color: var(--white);
      margin-bottom: 6px;
      line-height: 1.2;
    }

    .proj-desc {
      font-size: 12px;
      color: var(--text-dim);
      line-height: 1.6;
      font-weight: 300;
      font-style: italic;
      margin-bottom: 10px;
    }

    .proj-stack { display: flex; flex-wrap: wrap; gap: 4px; }
    .p-tag {
      font-family: 'Share Tech Mono', monospace;
      font-size: 9px;
      color: var(--text-dimmer);
      border: 1px solid var(--blue-line-major);
      padding: 1px 6px;
      letter-spacing: 0.05em;
    }

    /* REVISION BLOCK */
    .revision-block {
      border: 1px solid var(--accent);
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      margin-top: 32px;
    }

    .rev-col {
      padding: 8px 12px;
      border-right: 1px solid var(--accent);
    }
    .rev-col:last-child { border-right: none; }

    .rev-label {
      font-family: 'Share Tech Mono', monospace;
      font-size: 8px;
      letter-spacing: 0.2em;
      color: var(--text-dimmer);
      text-transform: uppercase;
      margin-bottom: 3px;
    }

    .rev-val {
      font-family: 'Share Tech Mono', monospace;
      font-size: 11px;
      color: var(--accent);
    }

    @media (max-width: 640px) {
      .title-block { grid-template-columns: 1fr; }
      .title-meta { display: none; }
      .hero-spec .spec-body { grid-template-columns: 1fr; }
      .project-grid { grid-template-columns: 1fr; }
      .revision-block { grid-template-columns: 1fr 1fr; }
    }

    .switcher {
      position: fixed;
      bottom: 20px;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      align-items: center;
      gap: 16px;
      background: var(--blue-dark);
      border: 1px solid var(--accent);
      color: var(--text-dim);
      padding: 8px 20px;
      font-size: 10px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      z-index: 200;
      white-space: nowrap;
      font-family: 'Share Tech Mono', monospace;
    }
    .switcher a { color: var(--accent); text-decoration: none; }
    .switcher a:hover { text-decoration: underline; }
  </style>
</head>
<body>
  <div class="page">

    <!-- TITLE BLOCK -->
    <div class="title-block">
      <div class="title-main">
        <div class="tb-label">Subject: Developer Portfolio</div>
        <div class="tb-name">PIOTR SZARAN</div>
        <div class="tb-sub">Software developer — open to full-time opportunities</div>
      </div>
      <div class="title-meta">
        <div class="tm-row">
          <div class="tm-key">Drawn by</div>
          <div class="tm-val">P. SZARAN</div>
        </div>
        <div class="tm-row">
          <div class="tm-key">Date</div>
          <div class="tm-val">2025-04-01</div>
        </div>
        <div class="tm-row">
          <div class="tm-key">Status</div>
          <div class="tm-val" style="color: #86EFAC;">AVAILABLE</div>
        </div>
      </div>
    </div>

    <!-- FIG. 1 — Developer Specification -->
    <div class="fig-label">Fig. 1 — Developer Specification</div>
    <div class="spec-block hero-spec">
      <div class="spec-header">
        <span class="spec-title">CANDIDATE_PROFILE :: v1.0</span>
        <span class="spec-tag">ref: PS-2025-001</span>
      </div>
      <div class="spec-body">
        <div class="field-group">
          <div class="field-key">Education</div>
          <div class="field-val">— update this field</div>
        </div>
        <div class="field-group">
          <div class="field-key">Currently</div>
          <div class="field-val">— update this field</div>
        </div>
        <div class="field-group" style="grid-column: 1 / -1;">
          <div class="field-key">Primary stack (proficient)</div>
          <div class="stack-chips">
            <span class="s-chip">TypeScript</span>
            <span class="s-chip">Node.js</span>
            <span class="s-chip">React</span>
            <span class="s-chip">PostgreSQL</span>
            <span class="s-chip">Astro</span>
            <span class="s-chip s-chip-dim">Docker</span>
            <span class="s-chip s-chip-dim">Bun</span>
          </div>
        </div>
      </div>
    </div>

    <!-- FIG. 2 — Project Index -->
    <div class="fig-label">Fig. 2 — Project Index</div>
    <div class="project-grid">

      <div class="proj-spec">
        <div class="proj-header">
          <span class="proj-cat-tag personal">Personal</span>
          <span class="proj-date">2025-03</span>
        </div>
        <div class="proj-body">
          <div class="proj-id">PROJ-001 / portfolio-v2</div>
          <div class="proj-name">Portfolio Site v2</div>
          <div class="proj-desc">Rebuilt with Astro, MDX, Tailwind. Zero JS to client by default.</div>
          <div class="proj-stack">
            <span class="p-tag">Astro</span>
            <span class="p-tag">MDX</span>
            <span class="p-tag">Tailwind</span>
            <span class="p-tag">Preact</span>
            <span class="p-tag">Vercel</span>
          </div>
        </div>
      </div>

      <div class="proj-spec">
        <div class="proj-header">
          <span class="proj-cat-tag freelance">Freelance</span>
          <span class="proj-date">2024-11</span>
        </div>
        <div class="proj-body">
          <div class="proj-id">PROJ-002 / ecommerce-dashboard</div>
          <div class="proj-name">E-Commerce Dashboard</div>
          <div class="proj-desc">Analytics and inventory for a UK fashion retailer. Real-time data via PostgreSQL.</div>
          <div class="proj-stack">
            <span class="p-tag">Next.js</span>
            <span class="p-tag">TypeScript</span>
            <span class="p-tag">Recharts</span>
            <span class="p-tag">PostgreSQL</span>
          </div>
        </div>
      </div>

      <div class="proj-spec">
        <div class="proj-header">
          <span class="proj-cat-tag work">Work</span>
          <span class="proj-date">2024-08</span>
        </div>
        <div class="proj-body">
          <div class="proj-id">PROJ-003 / dev-tools-suite</div>
          <div class="proj-name">Developer Tools Suite</div>
          <div class="proj-desc">CLI tooling and internal web dashboard for streamlined deployment pipelines.</div>
          <div class="proj-stack">
            <span class="p-tag">Node.js</span>
            <span class="p-tag">TypeScript</span>
            <span class="p-tag">React</span>
            <span class="p-tag">Docker</span>
          </div>
        </div>
      </div>

      <div class="proj-spec">
        <div class="proj-header">
          <span class="proj-cat-tag personal">Personal</span>
          <span class="proj-date">2024-05</span>
        </div>
        <div class="proj-body">
          <div class="proj-id">PROJ-004 / url-shortener-oss</div>
          <div class="proj-name">Open Source URL Shortener</div>
          <div class="proj-desc">Self-hosted shortener with analytics, custom domains, and a REST API. MIT.</div>
          <div class="proj-stack">
            <span class="p-tag">Bun</span>
            <span class="p-tag">Hono</span>
            <span class="p-tag">SQLite</span>
            <span class="p-tag">Fly.io</span>
          </div>
        </div>
      </div>
    </div>

    <!-- REVISION BLOCK -->
    <div class="revision-block">
      <div class="rev-col">
        <div class="rev-label">Document</div>
        <div class="rev-val">PS-PORTFOLIO</div>
      </div>
      <div class="rev-col">
        <div class="rev-label">Email</div>
        <div class="rev-val">piotr@piotrszaran.com</div>
      </div>
      <div class="rev-col">
        <div class="rev-label">GitHub</div>
        <div class="rev-val">github.com/piotrszaran</div>
      </div>
      <div class="rev-col">
        <div class="rev-label">Revision</div>
        <div class="rev-val">REV A</div>
      </div>
    </div>

  </div>

  <nav class="switcher">
    <a href="/9">←</a>
    <span>Design 10 / 10 — Blueprint</span>
    <a href="/1">→</a>
  </nav>
</body>
</html>
