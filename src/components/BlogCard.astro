---
import { formatDate } from '../lib/utils';

interface Props {
  slug: string;
  title: string;
  date: Date;
  description: string;
  readingTime?: number;
  tags?: string[];
}

const { slug, title, date, description, readingTime, tags } = Astro.props;
---

<a href={`/blog/${slug}`}
   class="block border border-gray-200 rounded-lg p-5 hover:border-gray-400 transition-colors">
  <div class="flex items-center gap-3 text-xs text-gray-500 mb-2">
    <time datetime={date.toISOString()}>{formatDate(date)}</time>
    {readingTime && (
      <>
        <span aria-hidden="true">·</span>
        <span>{readingTime} min read</span>
      </>
    )}
  </div>
  <h3 class="font-semibold text-lg mb-1">{title}</h3>
  <p class="text-gray-600 text-sm">{description}</p>
  {tags && tags.length > 0 && (
    <div class="flex flex-wrap gap-1.5 mt-3">
      {tags.map((tag) => (
        <span class="text-xs border border-gray-200 rounded-full px-2 py-0.5 text-gray-500">
          #{tag}
        </span>
      ))}
    </div>
  )}
</a>
