---
interface Props {
  stack: string[];
}

const { stack } = Astro.props;

const SKILL_ICON_MAP: Record<string, string> = {
  'TypeScript': 'ts',
  'JavaScript': 'js',
  'Next.js': 'nextjs',
  'Node.js': 'nodejs',
  'React': 'react',
  'Preact': 'react',
  'Vite': 'vite',
  'Tailwind': 'tailwind',
  'Tailwind CSS': 'tailwind',
  'Astro': 'astro',
  'HTML': 'html',
  'CSS': 'css',
  'Docker': 'docker',
  'Cloudflare': 'cloudflare',
  'GitHub Actions': 'githubactions',
  'PowerShell': 'powershell',
  'Raspberry Pi': 'raspberrypi',
  'PHP': 'php',
  'WordPress': 'wordpress',
  'Supabase': 'supabase',
  'Vercel': 'vercel',
  'Bun': 'bun',
  'Sanity': 'sanity',
  'Spotify API': 'spotify',
  'Framer Motion': 'framermotion',
  'WPF': 'dotnet',
};

const SIMPLE_ICON_MAP: Record<string, string> = {
  'MDX': 'mdx',
  'PM2': 'pm2',
  'Render': 'render',
  'Netlify': 'netlify',
  'Anthropic API': 'anthropic',
  'Payload': 'payloadcms',
  'Shadcn/ui': 'shadcnui',
  'NextAuth.js': 'authjs',
  'MariaDB': 'mariadb',
  'Resend': 'resend',
  'Claude Code': 'anthropic',
  'XAML': 'xaml',
};

const THEME_SIMPLE_ICON_COLOR_PLACEHOLDER = '__THEME_SIMPLE_ICON_COLOR__';
const DEFAULT_THEME_SIMPLE_ICON_COLOR = 'e2e8f0';
const THEME_AWARE_SIMPLE_ICON_IDS = new Set([
  'mdx',
  'payloadcms',
  'shadcnui',
  'authjs',
  'resend',
  'xaml',
]);

const getMonogram = (tech: string): string => {
  const cleaned = tech.replace(/[^a-zA-Z0-9+\s]/g, ' ').trim();
  if (!cleaned) return '?';

  const words = cleaned.split(/\s+/).filter(Boolean);
  if (words.length >= 2) return `${words[0][0]}${words[1][0]}`.toUpperCase();

  return cleaned.slice(0, 2).toUpperCase();
};

const getIconSources = (
  tech: string
): { primary: string | null; fallback: string | null; fallbackTemplate: string | null } => {
  const skillId = SKILL_ICON_MAP[tech];
  const simpleId = SIMPLE_ICON_MAP[tech];
  const isThemeAwareSimpleIcon = simpleId
    ? THEME_AWARE_SIMPLE_ICON_IDS.has(simpleId)
    : false;
  const simplePath = simpleId
    ? `https://cdn.simpleicons.org/${simpleId}${
        isThemeAwareSimpleIcon ? `/${DEFAULT_THEME_SIMPLE_ICON_COLOR}` : ''
      }`
    : null;
  const simpleTemplate = simpleId && isThemeAwareSimpleIcon
    ? `https://cdn.simpleicons.org/${simpleId}/${THEME_SIMPLE_ICON_COLOR_PLACEHOLDER}`
    : null;

  return {
    primary: skillId ? `https://skillicons.dev/icons?i=${skillId}` : null,
    fallback: simplePath,
    fallbackTemplate: simpleTemplate,
  };
};
---

<div class="flex flex-wrap gap-2 sm:gap-3">
  {stack.map((tech) => {
    const { primary, fallback, fallbackTemplate } = getIconSources(tech);
    const monogram = getMonogram(tech);

    return (
      <div>
        <div class="flex flex-col items-center gap-1.5 text-center sm:gap-2">
          <div class="relative flex h-10 w-10 items-center justify-center overflow-hidden rounded-lg border border-site-border bg-site-surface-hover sm:h-12 sm:w-12">
            {primary || fallback ? (
              <img
                src={primary ?? fallback!}
                data-fallback-src={fallback ?? ''}
                data-theme-simple-icon-template={!primary ? (fallbackTemplate ?? undefined) : undefined}
                alt={`${tech} logo`}
                title={tech}
                loading="lazy"
                class="h-8 w-8 object-contain sm:h-10 sm:w-10"
                onerror="if (this.dataset.fallbackSrc && this.src !== this.dataset.fallbackSrc) { this.src = this.dataset.fallbackSrc; return; } this.style.display='none'; const fallback = this.parentElement && this.parentElement.querySelector('[data-icon-fallback]'); if (fallback) fallback.style.display='flex';"
              />
            ) : null}
            <span
              data-icon-fallback
              class:list={[
                'absolute inset-0 items-center justify-center text-[11px] font-semibold tracking-wide text-site-subtext',
                primary || fallback ? 'hidden' : 'flex',
              ]}
              aria-hidden="true"
            >
              {monogram}
            </span>
          </div>
          <span class="text-[11px] leading-tight text-site-dim sm:text-xs hidden sm:block">{tech}</span>
        </div>
      </div>
    );
  })}
</div>
