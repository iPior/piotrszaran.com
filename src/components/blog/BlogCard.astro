---
import type { CollectionEntry } from "astro:content";
import { calculateReadingTime, formatDate } from "../../lib/utils";

interface Props {
  post: CollectionEntry<"blog">;
  itemNumber: number;
}

const { post, itemNumber } = Astro.props;
const readingTime =
  post.data.readingTime ?? calculateReadingTime(post.body ?? "");
---

<article class="border-b border-site-border py-4 transition-colors duration-100 hover:-mx-3 hover:rounded hover:bg-site-surface-hover hover:px-3">
  <div class="flex items-start gap-4">
    <div class="w-9 text-lg font-medium leading-tight text-site-peach max-sm:w-7">
      {String(itemNumber).padStart(2, "0")}
    </div>

    <div class="min-w-0 flex-1">
      <a href={`/blog/${post.slug}`} class="group inline-flex items-center gap-2">
        <h3 class="text-base font-semibold leading-snug text-site-blue">
          {post.data.title}
        </h3>
        <span class="text-site-dim transition-colors group-hover:text-site-blue">
          →
        </span>
      </a>
      <p class="mt-1 text-xs italic leading-relaxed text-site-dim">
        {post.data.description}
      </p>

      {post.data.tags && post.data.tags.length > 0 && (
        <div class="mt-2.5 flex flex-wrap gap-1">
          {post.data.tags.map((tag) => (
            <span class="rounded-sm border border-site-border px-1.5 py-0 text-xs text-site-peach">
              #{tag}
            </span>
          ))}
        </div>
      )}

      <div class="mt-2 flex items-center gap-3 text-xs text-site-dim sm:hidden">
        <time datetime={post.data.date.toISOString()}>
          {formatDate(post.data.date)}
        </time>
        <span aria-hidden="true">·</span>
        <span>{readingTime} min read</span>
      </div>
    </div>

    <div class="w-44 flex-col items-end gap-1 text-right max-sm:hidden flex">
      <time datetime={post.data.date.toISOString()} class="text-xs text-site-dim">
        {formatDate(post.data.date)}
      </time>
      <span class="text-xs text-site-green">
        {readingTime} min read
      </span>
    </div>
  </div>
</article>
