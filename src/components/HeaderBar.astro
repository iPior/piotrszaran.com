---
import BlogIcon from './icons/BlogIcon.astro';
import CheckIcon from './icons/CheckIcon.astro';
import ChevronDownIcon from './icons/ChevronDownIcon.astro';
import HomeIcon from './icons/HomeIcon.astro';
import MoonIcon from './icons/MoonIcon.astro';
import ProjectsIcon from './icons/ProjectsIcon.astro';
import SunIcon from './icons/SunIcon.astro';

const currentPath = Astro.url.pathname;

interface HeaderTab {
  label: string;
  href: string;
  icon: 'home' | 'blog' | 'projects';
}

const tabs = [
  { label: 'Home', href: '/', icon: 'home' },
  { label: 'Blogs', href: '/blogs', icon: 'blog' },
  { label: 'Projects', href: '/projects', icon: 'projects' }
] satisfies HeaderTab[];

const tabIcons = {
  home: HomeIcon,
  blog: BlogIcon,
  projects: ProjectsIcon
} as const;

const themeFamilies = [
  { id: 'catppuccin', label: 'Catppuccin' },
  { id: 'nord', label: 'Nord' }
] as const;

function isActive(href: string): boolean {
  if (href === '/') {
    return currentPath === '/';
  }

  return currentPath === href || currentPath.startsWith(`${href}/`);
}
---

<header class="border-b border-site-border bg-site-tab">
  <div class="mx-auto w-full max-w-5xl sm:px-6 lg:px-8">
    <div class="flex items-stretch justify-between text-xs">
      <nav class="flex min-w-0 items-stretch overflow-x-auto">
        {
          tabs.map((tab) => {
            const Icon = tabIcons[tab.icon];
            return (
              <a
                href={tab.href}
                class:list={[
                  'flex items-center gap-1.5 whitespace-nowrap border-r border-site-border px-3 py-2 sm:gap-2 sm:px-4',
                  isActive(tab.href)
                    ? '-mb-px border-b-2 border-site-blue bg-site-bg text-site-text'
                    : 'text-site-dim hover:text-site-subtext'
                ]}
              >
                <span aria-hidden="true" class="inline-flex h-3.5 w-3.5 items-center justify-center">
                  <Icon class="h-3.5 w-3.5" />
                </span>
                {tab.label}
              </a>
            );
          })
        }
      </nav>
      <div class="flex shrink-0 items-stretch">
        <details data-theme-menu class="theme-menu relative border-l border-r border-site-border">
          <summary class="flex h-full list-none cursor-pointer select-none items-center gap-1 px-2 py-2 text-site-dim leading-none transition-colors hover:bg-site-surface hover:text-site-text focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-site-blue/70 sm:gap-1.5 sm:px-3">
            <span class="hidden leading-none sm:inline">Theme</span>
            <ChevronDownIcon class="theme-menu-chevron h-3 w-3 transition-transform" />
          </summary>
          <div class="absolute right-0 top-full z-30 mt-2 min-w-40 rounded border border-site-border bg-site-surface p-1 shadow-xl">
            <div class="px-2 py-1 text-[10px] uppercase tracking-wide text-site-overlay">Palette</div>
            {
              themeFamilies.map((themeFamily) => (
                <button
                  type="button"
                  role="menuitemradio"
                  aria-checked="false"
                  data-theme-family-option={themeFamily.id}
                  data-active="false"
                  class="theme-family-option text-left text-xs"
                >
                  <span>{themeFamily.label}</span>
                  <span data-theme-family-check aria-hidden="true">
                    <CheckIcon class="h-3.5 w-3.5" />
                  </span>
                </button>
              ))
            }
          </div>
        </details>
        <button
          type="button"
          data-theme-toggle
          aria-label="Switch to light mode"
          aria-pressed="false"
          class="theme-toggle inline-flex items-center border-r border-site-border px-2 text-site-dim transition-colors hover:bg-site-surface hover:text-site-text focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-site-blue/70 sm:px-3"
        >
          <span class="relative inline-flex h-4 w-4 items-center justify-center" aria-hidden="true">
            <SunIcon class="theme-icon theme-icon--sun h-4 w-4" />
            <MoonIcon class="theme-icon theme-icon--moon h-4 w-4" />
          </span>
          <span class="sr-only">Toggle color theme</span>
        </button>
      </div>
    </div>
  </div>
</header>

<script is:inline>
  (() => {
    const root = document.documentElement;
    const toggles = document.querySelectorAll('[data-theme-toggle]');
    const familyOptions = document.querySelectorAll('[data-theme-family-option]');
    const menus = document.querySelectorAll('[data-theme-menu]');
    const defaultThemeShieldColor = '313244';
    const themeShieldColorPlaceholder = '__THEME_DEFAULT_BADGE_COLOR__';
    const defaultThemeSimpleIconColor = 'e2e8f0';
    const themeSimpleIconColorPlaceholder = '__THEME_SIMPLE_ICON_COLOR__';
    const validFamilies = ['catppuccin', 'nord'];
    if (!toggles.length && !familyOptions.length) return;

    const getTheme = () => (root.dataset.theme === 'light' ? 'light' : 'dark');
    const getThemeFamily = () => {
      const currentFamily = root.dataset.themeFamily;
      return validFamilies.includes(currentFamily) ? currentFamily : 'catppuccin';
    };
    const toShieldHexColor = (color) => {
      const value = color.trim();
      if (!value) return null;

      if (value.startsWith('#')) {
        const rawHex = value.slice(1);
        if (/^[0-9a-fA-F]{3}$/.test(rawHex)) {
          return rawHex
            .split('')
            .map((char) => `${char}${char}`)
            .join('')
            .toLowerCase();
        }
        if (/^[0-9a-fA-F]{6}$/.test(rawHex)) {
          return rawHex.toLowerCase();
        }
        return null;
      }

      const rgbMatch = value.match(
        /^rgba?\(\s*(\d{1,3})\s*,\s*(\d{1,3})\s*,\s*(\d{1,3})/i
      );
      if (!rgbMatch) return null;

      const toHex = (channel) => {
        const numeric = Number(channel);
        if (Number.isNaN(numeric)) return '00';
        const clamped = Math.max(0, Math.min(255, numeric));
        return clamped.toString(16).padStart(2, '0');
      };

      return `${toHex(rgbMatch[1])}${toHex(rgbMatch[2])}${toHex(rgbMatch[3])}`;
    };
    const getThemeShieldColor = () => {
      const rootStyles = getComputedStyle(root);
      const borderColor = rootStyles.getPropertyValue('--color-site-border');
      return toShieldHexColor(borderColor) ?? defaultThemeShieldColor;
    };
    const getThemeSimpleIconColor = () => {
      const rootStyles = getComputedStyle(root);
      const subtextColor = rootStyles.getPropertyValue('--color-site-subtext');
      return toShieldHexColor(subtextColor) ?? defaultThemeSimpleIconColor;
    };
    const syncThemeShieldBadges = () => {
      const nextColor = getThemeShieldColor();
      const badges = document.querySelectorAll('img[data-theme-shield-template]');
      badges.forEach((badge) => {
        const template = badge.dataset.themeShieldTemplate;
        if (!template) return;
        const nextSrc = template.replace(themeShieldColorPlaceholder, nextColor);
        if (badge.getAttribute('src') !== nextSrc) {
          badge.setAttribute('src', nextSrc);
        }
      });
    };
    const syncThemeSimpleIcons = () => {
      const nextColor = getThemeSimpleIconColor();
      const icons = document.querySelectorAll('img[data-theme-simple-icon-template]');
      icons.forEach((icon) => {
        const template = icon.dataset.themeSimpleIconTemplate;
        if (!template) return;
        const nextSrc = template.replace(themeSimpleIconColorPlaceholder, nextColor);
        if (icon.getAttribute('src') !== nextSrc) {
          icon.setAttribute('src', nextSrc);
        }
        if (icon.dataset.fallbackSrc !== nextSrc) {
          icon.dataset.fallbackSrc = nextSrc;
        }
      });
    };

    const syncToggleState = (theme) => {
      const isLight = theme === 'light';
      toggles.forEach((toggle) => {
        toggle.setAttribute('aria-pressed', String(isLight));
        toggle.setAttribute('aria-label', isLight ? 'Switch to dark mode' : 'Switch to light mode');
      });
    };

    const syncThemeFamilyState = (themeFamily) => {
      familyOptions.forEach((option) => {
        const isActive = option.dataset.themeFamilyOption === themeFamily;
        option.dataset.active = isActive ? 'true' : 'false';
        option.setAttribute('aria-checked', String(isActive));
      });
    };

    syncToggleState(getTheme());
    syncThemeFamilyState(getThemeFamily());
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', () => {
        syncThemeShieldBadges();
        syncThemeSimpleIcons();
      });
    } else {
      syncThemeShieldBadges();
      syncThemeSimpleIcons();
    }

    toggles.forEach((toggle) => {
      toggle.addEventListener('click', () => {
        const nextTheme = getTheme() === 'dark' ? 'light' : 'dark';
        root.dataset.theme = nextTheme;
        localStorage.setItem('theme', nextTheme);
        syncToggleState(nextTheme);
        syncThemeShieldBadges();
        syncThemeSimpleIcons();
      });
    });

    familyOptions.forEach((option) => {
      option.addEventListener('click', () => {
        const nextFamily = option.dataset.themeFamilyOption;
        if (!validFamilies.includes(nextFamily)) return;
        root.dataset.themeFamily = nextFamily;
        localStorage.setItem('themeFamily', nextFamily);
        syncThemeFamilyState(nextFamily);
        syncThemeShieldBadges();
        syncThemeSimpleIcons();
        const openMenu = option.closest('details');
        if (openMenu) {
          openMenu.removeAttribute('open');
        }
      });
    });

    document.addEventListener('click', (event) => {
      if (!(event.target instanceof Node)) return;
      menus.forEach((menu) => {
        if (!menu.contains(event.target)) {
          menu.removeAttribute('open');
        }
      });
    });

    const badgeObserver = new MutationObserver(() => {
      syncThemeShieldBadges();
      syncThemeSimpleIcons();
    });
    if (document.body) {
      badgeObserver.observe(document.body, { childList: true, subtree: true });
    }
  })();
</script>
