---
import CategoryBadge from './CategoryBadge.astro';
import StackPills from './StackPills.astro';
import { formatDate } from '../lib/utils';

interface Props {
  slug: string;
  title: string;
  date: Date;
  category: 'freelance' | 'work' | 'personal';
  description: string;
  stack?: string[];
  thumbnail?: string;
  liveUrl?: string;
  githubUrl?: string;
}

const { slug, title, date, category, description, stack, thumbnail, liveUrl, githubUrl } = Astro.props;
---

<a href={`/projects/${slug}`}
   class="block border border-gray-200 rounded-lg p-5 hover:border-gray-400 transition-colors">
  {thumbnail && (
    <img src={thumbnail} alt={title} class="w-full h-40 object-cover rounded mb-4" loading="lazy" />
  )}
  <div class="flex items-center gap-3 mb-2">
    <CategoryBadge category={category} />
    <time class="text-xs text-gray-500">{formatDate(date)}</time>
  </div>
  <h3 class="font-semibold text-lg mb-1">{title}</h3>
  <p class="text-gray-600 text-sm mb-3">{description}</p>
  {stack && stack.length > 0 && <StackPills stack={stack} />}
  <div class="flex gap-3 mt-3 text-xs text-blue-600">
    {liveUrl && <span>Live ↗</span>}
    {githubUrl && <span>GitHub ↗</span>}
  </div>
</a>
