---
const currentPath = Astro.url.pathname;

function isActive(path: string): boolean {
  if (path === '/') return currentPath === '/';
  return currentPath.startsWith(path);
}
---

<nav class="border-b border-gray-200 bg-white">
  <div class="max-w-4xl mx-auto px-4 py-4 flex items-center justify-between">
    <a href="/" class="font-semibold text-gray-900 hover:text-gray-600">Piotr Szaran</a>
    <div class="flex gap-6 text-sm">
      <a href="/"
         class={`hover:text-gray-900 ${isActive('/') ? 'text-gray-900 font-medium' : 'text-gray-600'}`}>
        Home
      </a>
      <a href="/blog"
         class={`hover:text-gray-900 ${isActive('/blog') ? 'text-gray-900 font-medium' : 'text-gray-600'}`}>
        Blog
      </a>
    </div>
  </div>
</nav>
