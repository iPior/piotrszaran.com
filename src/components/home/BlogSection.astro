---
import { formatDate } from '../../lib/utils';

interface HomeBlogEntry {
  slug: string;
  title: string;
  description: string;
  date: Date;
  readingTime: number;
  tags: string[];
}

interface Props {
  posts: HomeBlogEntry[];
}

const { posts } = Astro.props;
---

<section>
  <div class="mt-20 flex items-baseline justify-between gap-3 border-b border-site-border pb-2.5">
    <div class="flex items-baseline gap-3">
      <h2 class="text-2xl font-semibold text-site-text">
        <span class="font-normal text-site-mauve">const</span> <span class="text-site-yellow">blogPosts</span>
      </h2>
      <span class="text-xs text-site-dim">// {posts.length} items</span>
    </div>
    <a href="/blog" class="text-xs text-site-blue hover:underline">View all →</a>
  </div>

  {
    posts.length === 0 ? (
      <p class="py-6 text-site-dim">No posts yet.</p>
    ) : (
      <div>
        {
          posts.map((post, idx) => (
            <article class="border-b border-site-border py-4 transition-colors duration-100 hover:-mx-3 hover:rounded hover:bg-site-surface-hover hover:px-3">
              <div class="flex items-start gap-4">
                <div class="w-9 text-lg font-medium leading-tight text-site-peach max-sm:w-7">
                  {String(idx + 1).padStart(2, '0')}
                </div>

                <div class="min-w-0 flex-1">
                  <a href={`/blog/${post.slug}`} class="group inline-flex items-center gap-2">
                    <h3 class="text-base font-semibold leading-snug text-site-blue">{post.title}</h3>
                    <span class="text-site-dim transition-colors group-hover:text-site-blue">→</span>
                  </a>
                  <p class="mt-1 text-xs italic leading-relaxed text-site-dim">{post.description}</p>

                  {post.tags.length > 0 && (
                    <div class="mt-2.5 flex flex-wrap gap-1">
                      {post.tags.map((tag) => (
                        <span class="rounded-sm border border-site-border px-1.5 py-0 text-xs text-site-dim">#{tag}</span>
                      ))}
                    </div>
                  )}

                  <div class="mt-2 flex items-center gap-3 text-xs text-site-dim sm:hidden">
                    <time datetime={post.date.toISOString()}>{formatDate(post.date)}</time>
                    <span aria-hidden="true">·</span>
                    <span>{post.readingTime} min read</span>
                  </div>
                </div>

                <div class="w-44 flex-col items-end gap-1 text-right max-sm:hidden flex">
                  <time datetime={post.date.toISOString()} class="text-xs text-site-dim">
                    {formatDate(post.date)}
                  </time>
                  <span class="text-xs text-site-green">{post.readingTime} min read</span>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    )
  }
</section>
