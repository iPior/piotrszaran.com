---
import type { IdeTab } from '../../data/home/ideHome';

interface Props {
  tabs: IdeTab[];
}

const { tabs } = Astro.props;
---

<div class="flex items-stretch overflow-x-auto border-b border-ide-border bg-ide-tab text-xs">
  {
    tabs.map((tab) => (
      <div
        class:list={[
          'flex items-center gap-2 whitespace-nowrap border-r border-ide-border px-4 py-2',
          tab.active ? '-mb-px border-b-2 border-ide-blue bg-ide-bg text-ide-text' : 'text-ide-dim'
        ]}
      >
        <span class:list={['text-xs', tab.iconClass]}>{tab.icon}</span>
        {tab.label}
      </div>
    ))
  }
</div>
