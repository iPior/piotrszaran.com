---
interface Props {
  leftItems: string[];
  rightItems: string[];
}

const { leftItems, rightItems } = Astro.props;
---

<div class="fixed inset-x-0 bottom-12 z-40 flex items-center justify-between border-t border-site-border bg-site-surface px-4 py-1 text-xs text-site-dim max-sm:hidden">
  <div class="flex items-center gap-3.5">
    {
      leftItems.map((item, idx) => (
        <span class:list={idx === 0 ? 'text-site-blue' : ''}>{item}</span>
      ))
    }
  </div>
  <div class="flex items-center gap-3.5">
    {
      rightItems.map((item, idx) => (
        <span class:list={idx === rightItems.length - 1 ? 'text-site-green' : ''}>{item}</span>
      ))
    }
  </div>
</div>
