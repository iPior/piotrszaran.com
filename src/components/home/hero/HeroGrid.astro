---
import type { ProfileField } from "./types";
import StackPills from "../../projects/StackPills.astro";

interface Props {
  profileFields: ProfileField[];
  coreStack: string[];
}

const { profileFields, coreStack } = Astro.props;

const normalizeKey = (key: string) => key.trim().toLowerCase();
const preferredOrder = ["education", "location", "experience"];
const profileFieldsByKey = new Map(
  profileFields.map((field) => [normalizeKey(field.key), field]),
);
const orderedProfileFields = [
  ...preferredOrder
    .map((key) => profileFieldsByKey.get(key))
    .filter((field): field is ProfileField => Boolean(field)),
  ...profileFields.filter(
    (field) => !preferredOrder.includes(normalizeKey(field.key)),
  ),
];
const totalCells = 1 + orderedProfileFields.length;
const totalRowsDesktop = Math.ceil(totalCells / 2);
---

<div
  class="mt-5 grid grid-cols-1 overflow-hidden rounded border border-site-border bg-site-surface md:mt-6 md:grid-cols-2"
>
  <div
    class:list={[
      "border-site-border px-3 py-3 md:border-r md:px-4 md:py-3.5",
      totalCells > 1 ? "border-b" : "",
      totalRowsDesktop > 1 ? "md:border-b" : "",
    ]}
  >
    <div class="mb-1 text-xs font-normal text-site-mauve">
      <span class="text-site-overlay">. </span>coreStack
    </div>
    <div class="mt-2">
      <StackPills stack={coreStack} />
    </div>
  </div>
  {
    orderedProfileFields.map((field, idx) => {
      return (
        <div
          class:list={[
            "border-site-border px-3 py-3 md:px-4 md:py-3.5",
            idx + 1 < totalCells ? "border-b" : "",
            (idx + 1) % 2 === 0 ? "md:border-r" : "",
            Math.floor((idx + 1) / 2) < totalRowsDesktop - 1 ? "md:border-b" : "",
          ]}
        >
          <div class="mb-1 text-xs font-normal text-site-mauve">
            <span class="text-site-overlay">.</span>
            {field.key}
          </div>
          <div class="text-sm text-site-text pl-4">
            <Fragment set:html={field.value} />
          </div>
        </div>
      );
    })
  }
</div>
