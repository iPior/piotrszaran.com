---
import EmailIcon from '../../icons/EmailIcon.astro';
import GithubIcon from '../../icons/GithubIcon.astro';
import LinkedInIcon from '../../icons/LinkedInIcon.astro';
import ResumeIcon from '../../icons/ResumeIcon.astro';
import WebsiteIcon from '../../icons/WebsiteIcon.astro';
import XIcon from '../../icons/XIcon.astro';
import type { SocialLink } from './types';

interface Props {
  socialLinks: SocialLink[];
  resumeHref?: string;
  resumeLabel?: string;
}

const {
  socialLinks,
  resumeHref,
  resumeLabel = 'Resume',
} = Astro.props;

const isExternal = (href: string): boolean => /^https?:\/\//.test(href);

const socialIcons = {
  github: GithubIcon,
  linkedin: LinkedInIcon,
  x: XIcon,
  email: EmailIcon,
  website: WebsiteIcon,
} as const;
---

{
  (socialLinks.length > 0 || resumeHref) && (
    <div class="mt-3.5 flex flex-wrap items-center gap-1.5 sm:mt-4 sm:gap-2">
      {socialLinks.map((social) => {
        const Icon = socialIcons[social.icon];
        const iconClass =
          social.icon === 'linkedin' || social.icon === 'email'
            ? 'h-5 w-5 sm:h-6 sm:w-6'
            : 'h-5 w-5';

        return (
          <a
            href={social.href}
            aria-label={social.label}
            title={social.label}
            target={isExternal(social.href) ? '_blank' : undefined}
            rel={isExternal(social.href) ? 'noopener noreferrer' : undefined}
            class="inline-flex h-8 w-8 items-center justify-center rounded border border-site-border bg-site-surface text-site-dim transition-colors hover:bg-site-surface-hover hover:text-site-text sm:h-9 sm:w-9"
          >
            <Icon class={iconClass} />
            <span class="sr-only">{social.label}</span>
          </a>
        );
      })}
      {
        resumeHref && (
          <a
            href={resumeHref}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={resumeLabel}
            class="inline-flex h-8 items-center justify-center rounded border border-site-border bg-site-surface px-1.5 text-[11px] text-site-dim transition-colors hover:bg-site-surface-hover sm:h-9 sm:px-1 sm:text-xs"
          >
            <ResumeIcon class="h-5 w-5 sm:h-6 sm:w-6" />
            {/* <span class="bg-red-200 inline-flex items-center leading-none">{resumeLabel}</span> */}
          </a>
        )
      }
    </div>
  )
}
