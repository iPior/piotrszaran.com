---
import type { SocialLink } from './types';

interface Props {
  socialLinks: SocialLink[];
}

const { socialLinks } = Astro.props;

const isExternal = (href: string): boolean => /^https?:\/\//.test(href);
---

{
  socialLinks.length > 0 && (
    <div class="mt-4 flex flex-wrap items-center gap-2">
      {socialLinks.map((social) => (
        <a
          href={social.href}
          aria-label={social.label}
          title={social.label}
          target={isExternal(social.href) ? '_blank' : undefined}
          rel={isExternal(social.href) ? 'noopener noreferrer' : undefined}
          class="inline-flex h-9 w-9 items-center justify-center rounded border border-site-border bg-site-surface text-site-dim transition-colors hover:bg-site-surface-hover hover:text-site-text"
        >
          {social.icon === 'github' && (
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor" aria-hidden="true">
              <path d="M12 .5a12 12 0 0 0-3.8 23.4c.6.1.8-.2.8-.6v-2.1c-3.4.8-4.1-1.5-4.1-1.5-.6-1.4-1.3-1.8-1.3-1.8-1.1-.8.1-.8.1-.8 1.2.1 1.9 1.2 1.9 1.2 1.1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.8-1.6-2.7-.3-5.5-1.3-5.5-6 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.2 1.2a11 11 0 0 1 5.9 0C17.9 5 19 5.3 19 5.3c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.7-2.8 5.7-5.5 6 .5.4.9 1.1.9 2.3v3.4c0 .4.2.7.8.6A12 12 0 0 0 12 .5Z" />
            </svg>
          )}
          {social.icon === 'linkedin' && (
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor" aria-hidden="true">
              <path d="M5 3.5A1.5 1.5 0 1 0 5 6.5 1.5 1.5 0 0 0 5 3.5ZM3.7 8h2.6v12H3.7V8Zm6.1 0h2.5v1.7h.1c.3-.6 1.2-2 3.3-2 3.6 0 4.3 2.4 4.3 5.5V20h-2.6v-6.1c0-1.5 0-3.4-2.1-3.4-2.1 0-2.4 1.6-2.4 3.3V20H9.8V8Z" />
            </svg>
          )}
          {social.icon === 'x' && (
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor" aria-hidden="true">
              <path d="M18.9 2H22l-6.7 7.7L23 22h-6l-4.7-6.2L6.8 22H3.7l7.2-8.2L1 2h6.1l4.2 5.6L18.9 2Zm-1 18h1.7L6.1 3.9H4.3L17.9 20Z" />
            </svg>
          )}
          {social.icon === 'email' && (
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" aria-hidden="true">
              <rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.5" />
              <path d="m4.5 7 7.5 6 7.5-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          )}
          {social.icon === 'website' && (
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" aria-hidden="true">
              <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5" />
              <path d="M3 12h18M12 3c2.5 2.3 3.7 5.3 3.7 9S14.5 18.7 12 21M12 3C9.5 5.3 8.3 8.3 8.3 12s1.2 6.7 3.7 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
            </svg>
          )}
          <span class="sr-only">{social.label}</span>
        </a>
      ))}
    </div>
  )
}
