---
import type { CollectionEntry } from 'astro:content';
import ProjectCard from '../projects/ProjectCard';

interface Props {
  projects: CollectionEntry<'projects'>[];
}

const { projects } = Astro.props;
---

<section>
  <div class="mt-10 flex items-baseline justify-between gap-3 border-b border-site-border pb-2.5">
    <div class="flex items-baseline gap-3">
      <h2 class="text-lg font-semibold text-site-text"><span class="font-normal text-site-mauve">const</span> <span class="text-site-yellow">projects</span></h2>
      <span class="text-xs text-site-dim">// {projects.length} items</span>
    </div>
    <a href="/projects" class="text-xs text-site-blue hover:underline">View all →</a>
  </div>

  {
    projects.length === 0 ? (
      <p class="py-6 text-site-dim">No projects yet.</p>
    ) : (
      <div>
        {projects.map((project, idx) => (
          <ProjectCard
            index={idx}
            title={project.data.title}
            description={project.data.description}
            category={project.data.category}
            href={`/projects/${project.slug}`}
            dateLabel={project.data.date.toLocaleDateString('en-US', {
              month: 'short',
              year: 'numeric'
            })}
            tags={project.data.stack ?? []}
            layout="home"
            tagColorMode="uniform"
          />
        ))}
      </div>
    )
  }
</section>
