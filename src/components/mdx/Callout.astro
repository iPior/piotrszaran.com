---
interface Props {
  type?: 'info' | 'warning' | 'tip';
}

const { type = 'info' } = Astro.props;

const styles = {
  info: 'bg-site-blue/10 border-site-blue text-site-text',
  warning: 'bg-site-yellow/10 border-site-yellow text-site-text',
  tip: 'bg-site-green/10 border-site-green text-site-text',
};

const icons = {
  info: 'ℹ',
  warning: '⚠',
  tip: '✓',
};
---

<aside class={`border-l-4 p-4 rounded-r my-6 ${styles[type]}`} role="note">
  <span class="font-bold mr-2" aria-hidden="true">{icons[type]}</span>
  <slot />
</aside>
