---
interface Props {
  src: string;
  alt: string;
  caption?: string;
}

const { src, alt, caption } = Astro.props;
---

<figure class="my-6">
  <img src={src} alt={alt} class="w-full rounded-lg" loading="lazy" />
  {caption && (
    <figcaption class="text-sm text-site-dim text-center mt-2">{caption}</figcaption>
  )}
</figure>
