---
import HeroGrid from './hero/HeroGrid.astro';
import HeroHeader from './hero/HeroHeader.astro';
import HeroSocials from './hero/HeroSocials.astro';
import type { ProfileField, SocialLink } from './hero/types';

interface Props {
  firstName: string;
  lastName: string;
  role: string;
  profileImageSrc?: string;
  profileImageAlt?: string;
  profileFields?: ProfileField[];
  coreStack?: string[];
  socialLinks?: SocialLink[];
  resumeHref?: string;
  resumeLabel?: string;
}

const defaultProfileFields: ProfileField[] = [
  { key: "experience", value: "2+ Years of Experience" },
  { key: "location", value: "Toronto" },
  {
    key: "education",
    value:
      "Honors Bachelor of Science<br />University of Toronto, 2023",
    },
];

const defaultCoreStack = ["TypeScript", "Node.js", "React", "Next.js", "Tailwind", "Bun"];

const defaultSocialLinks: SocialLink[] = [
  { label: "GitHub", href: "https://github.com/ipior", icon: "github" },
  { label: "LinkedIn", href: "https://www.linkedin.com/in/piotrszaran", icon: "linkedin" },
  { label: "Email", href: "mailto:szaranpiotr@gmail.com", icon: "email" },
];

const {
  firstName,
  lastName,
  role,
  profileImageSrc,
  profileImageAlt = `${firstName} ${lastName} profile photo`,
  profileFields = defaultProfileFields,
  coreStack = defaultCoreStack,
  socialLinks = defaultSocialLinks,
  resumeHref = '/resume.pdf',
  resumeLabel = 'Resume',
} = Astro.props;
---

<section class="pt-6 sm:pt-9">
  <HeroHeader
    firstName={firstName}
    lastName={lastName}
    role={role}
    profileImageSrc={profileImageSrc}
    profileImageAlt={profileImageAlt}
  />
  <HeroSocials socialLinks={socialLinks} resumeHref={resumeHref} resumeLabel={resumeLabel} />
  <HeroGrid profileFields={profileFields} coreStack={coreStack} />
</section>
