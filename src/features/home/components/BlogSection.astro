---
import type { CollectionEntry } from 'astro:content';
import BlogCard from '../../blog/components/BlogCard.astro';

interface Props {
  posts: CollectionEntry<'blog'>[];
  totalPosts: number;
}

const { posts, totalPosts } = Astro.props;
---

<section>
  <div class="mt-14 flex flex-wrap items-baseline justify-between gap-x-3 gap-y-2 border-b border-site-border pb-2.5 sm:mt-20">
    <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
      <h2 class="text-xl font-semibold text-site-text sm:text-2xl">
        <span class="font-normal text-site-mauve">const</span> <span class="text-site-yellow">blogPosts</span>
      </h2>
      <span class="text-xs text-site-dim">// {totalPosts} items</span>
    </div>
  </div>

  {
    posts.length === 0 ? (
      <p class="py-6 text-site-dim">No posts yet.</p>
    ) : (
      <>
        <div>
          {posts.map((post, idx) => <BlogCard post={post} itemNumber={totalPosts - idx} />)}
        </div>

        <div class="mt-4 flex items-center justify-between gap-3">
          <span class="text-xs text-site-dim">showing last {posts.length} blogs ...</span>
          <a
            href="/blogs"
            class="shrink-0 text-xs text-site-blue hover:underline"
          >
            View all →
          </a>
        </div>
      </>
    )
  }
</section>
