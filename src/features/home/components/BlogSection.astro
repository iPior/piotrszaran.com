---
import type { CollectionEntry } from 'astro:content';
import BlogCard from '../../blog/components/BlogCard.astro';

interface Props {
  posts: CollectionEntry<'blog'>[];
}

const { posts } = Astro.props;
---

<section>
  <div class="mt-14 flex flex-wrap items-baseline justify-between gap-x-3 gap-y-2 border-b border-site-border pb-2.5 sm:mt-20">
    <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
      <h2 class="text-xl font-semibold text-site-text sm:text-2xl">
        <span class="font-normal text-site-mauve">const</span> <span class="text-site-yellow">blogPosts</span>
      </h2>
      <span class="text-xs text-site-dim">// {posts.length} items</span>
    </div>
    <a href="/blogs" class="hidden shrink-0 text-xs text-site-blue hover:underline sm:block">View all →</a>
  </div>

  {
    posts.length === 0 ? (
      <p class="py-6 text-site-dim">No posts yet.</p>
    ) : (
      <div>
        {posts.map((post, idx) => <BlogCard post={post} itemNumber={posts.length - idx} />)}
      </div>
    )
  }
</section>
